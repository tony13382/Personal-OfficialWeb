---
import { Image } from "astro:assets";
import Icon from "@/components/Icon.astro";
import { MobileNav } from "@/components/header/MobileNav";
import { mainLinks } from "@/components/header/index";
import { SearchDialog } from "@/components/search/SearchDialog";
import profileImg from "@/assets/imgs/index/profileAnimate.png";
import brandSignUrl from "@/assets/imgs/index/brand-sign.svg?url";


interface Props {
  type?: "main" | "project" | "app";
  themeColor?: string;
  appName?: string;
  projectHref?: string;
  appUrl?: string;
}

const { type = "main", themeColor, appName, projectHref, appUrl } = Astro.props;
---


<header
  class="fixed top-0 left-0 right-0 z-40 py-2 bg-background border-b"
>
  <nav class="max-w-8xl mx-auto px-4 md:px-12">
    <div class="flex items-center justify-between">
      <!-- Logo / Brand -->
      {
        type === "main" ? (
          <a
            href="/"
            class="flex items-center gap-3 py-3 text-foreground font-semibold no-underline transition-opacity hover:opacity-100 hover:[&>#headerLogo]:ring-2"
          >
            <Image
              id="headerLogo"
              src={profileImg}
              alt="Logo"
              width={80}
              height={80}
              loading="eager"
              class="flex-shrink-0 size-10 rounded-full"
            />
            <span
              role="img"
              aria-label="LuMakes brand sign"
              class="block h-8 bg-foreground"
              style={`width: calc(7 * 968 / 376 * 0.25rem); -webkit-mask: url(${brandSignUrl}) no-repeat center / contain; mask: url(${brandSignUrl}) no-repeat center / contain;`}
            />
          </a>
        ) : type === "app" ? (
          <div class="flex items-center gap-1">
            <button
              onclick="history.back()"
              class="flex items-center text-foreground font-bold no-underline transition-opacity hover:bg-muted p-4 rounded-full cursor-pointer border-0 bg-transparent"
            >
              <Icon name="arrow-left" class="size-6" />
            </button>
            {appName && (
              <span class="text-foreground font-semibold text-lg">{appName}</span>
            )}
          </div>
        ) : (
          <button
            onclick="history.back()"
            class="flex items-center text-foreground font-bold no-underline transition-opacity hover:bg-muted p-4 rounded-full cursor-pointer border-0 bg-transparent"
          >
            <Icon name="arrow-left" class="size-6" />
          </button>
        )
      }

      <!-- Desktop Navigation -->
      {type === "app" ? (
        <div class="flex items-center gap-0.5">
          {projectHref && (
            <a
              href={projectHref}
              class="flex items-center gap-2 px-4 py-2 text-muted-foreground no-underline text-base rounded-full transition-all hover:text-primary hover:bg-muted whitespace-nowrap"
            >
              <Icon name="projector-screen-chart" class="size-5" />
              介紹
            </a>
          )}
          {appUrl && (
            <a
              href={appUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-4 py-2 text-muted-foreground no-underline text-base rounded-full transition-all hover:text-primary hover:bg-muted whitespace-nowrap"
            >
              <Icon name="arrow-square-out" class="size-5" />
              開啟
            </a>
          )}
        </div>
      ) : (
        <>
          <div class="hidden lg:flex items-center gap-0">
            {mainLinks.map((link) => (
              <a
                href={link.href}
                class="flex items-center gap-2 px-4 py-2 text-muted-foreground no-underline text-lg rounded-full transition-all hover:text-primary hover:bg-muted whitespace-nowrap"
              >
                {link.label}
              </a>
            ))}
            <span class="text-muted-foreground px-2">｜</span>
            <SearchDialog client:load />
          </div>

          <!-- Mobile Navigation (Sheet) -->
          <MobileNav client:load type={type} themeColor={themeColor} />
        </>
      )}
    </div>
  </nav>
</header>
