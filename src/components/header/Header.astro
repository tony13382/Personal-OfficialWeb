---
import { Image } from "astro:assets";
import Icon from "@/components/Icon.astro";
import { MobileNav } from "@/components/header/MobileNav";
import { getMainLinks } from "@/components/header/index";
import { SearchDialog } from "@/components/search/SearchDialog";
import brandFlatLogoImg from "@/assets/imgs/index/brandFlatLogoImg.svg?url";
import brandSignUrl from "@/assets/imgs/index/brand-sign.svg?url";
import { useTranslations, type Locale } from "@/i18n";


interface Props {
  type?: "main" | "project" | "app";
  themeColor?: string;
  appName?: string;
  projectHref?: string;
  appUrl?: string;
  locale?: Locale;
}

const { type = "main", themeColor, appName, projectHref, appUrl, locale = "zh-Hant" } = Astro.props;
const t = useTranslations(locale);
const navLinks = getMainLinks(locale);
const homeHref = locale === 'en' ? '/en/' : '/';
const cssUrl = (raw: string) => raw.replaceAll("'", "%27");
---


<header
  class="fixed top-0 left-0 right-0 z-40 py-2 bg-background border-b"
>
  <nav class="max-w-8xl mx-auto px-4 md:px-12">
    <div class="flex items-center justify-between">
      <!-- Logo / Brand -->
      {
        type === "main" ? (
          <a
            href={homeHref}
            class="flex items-center gap-3 py-2 text-foreground font-semibold no-underline transition-opacity hover:opacity-100 hover:[&>#headerLogo]:ring-2"
          >
              <div class="flex items-center justify-end gap-1.5">
                <span
                  role="img"
                  aria-label="LuMakes signature"
                  class="block h-11 w-auto opacity-75 rounded-full bg-foreground"
                  style={`width: calc(11 * 100 / 100 * 0.25rem); -webkit-mask: url(${cssUrl(brandFlatLogoImg)}) no-repeat center / contain; mask: url(${cssUrl(brandFlatLogoImg)}) no-repeat center / contain;`}
                ></span>
                <span
                  role="img"
                  aria-label="LuMakes signature"
                  class="block h-9 w-auto opacity-75 bg-foreground"
                  style={`width: calc(9 * 7208 / 3200 * 0.25rem); -webkit-mask: url(${cssUrl(brandSignUrl)}) no-repeat center / contain; mask: url(${cssUrl(brandSignUrl)}) no-repeat center / contain;`}
                ></span>
              </div>
          </a>
        ) : type === "app" ? (
          <div class="flex items-center gap-1">
            <button
              onclick="history.back()"
              class="flex items-center text-foreground font-bold no-underline transition-opacity hover:bg-muted p-4 rounded-full cursor-pointer border-0 bg-transparent"
            >
              <Icon name="arrow-left" class="size-6" />
            </button>
            {appName && (
              <span class="text-foreground font-semibold text-lg">{appName}</span>
            )}
          </div>
        ) : (
          <button
            onclick="history.back()"
            class="flex items-center text-foreground font-bold no-underline transition-opacity hover:bg-muted p-4 rounded-full cursor-pointer border-0 bg-transparent"
          >
            <Icon name="arrow-left" class="size-6" />
          </button>
        )
      }

      <!-- Desktop Navigation -->
      {type === "app" ? (
        <div class="flex items-center gap-0.5">
          {projectHref && (
            <a
              href={projectHref}
              class="flex items-center gap-2 px-4 py-2 text-muted-foreground no-underline text-base rounded-full transition-all hover:text-primary hover:bg-muted whitespace-nowrap"
            >
              <Icon name="projector-screen-chart" class="size-5" />
              {t.header.intro}
            </a>
          )}
          {appUrl && (
            <a
              href={appUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-4 py-2 text-muted-foreground no-underline text-base rounded-full transition-all hover:text-primary hover:bg-muted whitespace-nowrap"
            >
              <Icon name="arrow-square-out" class="size-5" />
              {t.header.open}
            </a>
          )}
        </div>
      ) : (
        <>
          <div class="hidden lg:flex items-center gap-0">
            {navLinks.map((link) => (
              <a
                href={link.href}
                class="flex items-center gap-2 px-4 py-2 text-muted-foreground no-underline text-lg rounded-full transition-all hover:text-primary hover:bg-muted whitespace-nowrap"
              >
                {link.label}
              </a>
            ))}
            <span class="text-muted-foreground px-2">｜</span>
            <SearchDialog locale={locale} client:load />
          </div>

          <!-- Mobile Navigation (Sheet) -->
          <MobileNav client:load type={type} themeColor={themeColor} locale={locale} />
        </>
      )}
    </div>
  </nav>
</header>
