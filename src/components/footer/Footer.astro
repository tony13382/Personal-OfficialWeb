---
import Icon from "@/components/Icon.astro";
import { SocialLinksLite } from "../data/social";
import ThemeToggle from "@/components/footer/ThemeToggle";
import LanguageSwitcher from "@/components/footer/LanguageSwitcher.astro";
import brandFlatLogoImg from "@/assets/imgs/index/brandFlatLogoImg.svg?url";
import brandSignUrl from "@/assets/imgs/index/brand-sign.svg?url";
import signUrl from "@/assets/imgs/index/sign.svg?url";
import { apps, getAppName } from "@/data/apps";
import { useTranslations, type Locale } from "@/i18n";

interface Props {
  locale?: Locale;
}

const { locale = "zh-Hant" } = Astro.props;
const t = useTranslations(locale);

// Encode single quotes in SVG data URIs to prevent breaking CSS url()
const cssUrl = (raw: string) => raw.replaceAll("'", "%27");
---

<footer class="rounded-t-3xl bg-background border-t border-0">
  <div class="max-w-8xl mx-auto px-4 md:px-12 py-8">
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-start"
    >
      <!-- Links Section -->
      <div
        class="grid col-span-1 lg:col-span-2 grid-cols-1 lg:grid-cols-2 gap-8"
      >
        <div class="col-span-1">
          <h4 class="text-xl text-muted-foreground font-semibold mb-2 px-4">
            {t.footer.products}
          </h4>
          {
            apps.map((app) => (
              <a
                href={`${locale === "en" ? "/en" : ""}/apps/${app.slug}/`}
                rel="noopener noreferrer"
                class="flex items-center px-4 py-2 gap-3 text-muted-foreground hover:bg-muted transition-colors no-underline group rounded-full"
              >
                <Icon
                  name={app.footerIcon}
                  class="size-5 group-hover:scale-110 transition-transform"
                />
                <span>{getAppName(app, locale)}</span>
              </a>
            ))
          }
        </div>
        <div class="col-span-1">
          <h4 class="text-xl text-muted-foreground font-semibold mb-2 px-4">
            {t.footer.links}
          </h4>
          <a
            href="https://go.lumakes.com/learn"
            rel="noopener noreferrer"
            class="flex items-center px-4 py-2 gap-3 text-muted-foreground hover:bg-muted transition-colors no-underline group rounded-full"
          >
            <Icon
              name="graduation-cap"
              class="size-5 group-hover:scale-110 transition-transform"
            />
            <span>{t.footer.knowledgeResources}</span>
          </a>
          <a
            href="https://go.lumakes.com/bm"
            rel="noopener noreferrer"
            class="flex items-center px-4 py-2 gap-3 text-muted-foreground hover:bg-muted transition-colors no-underline group rounded-full"
          >
            <Icon
              name="bookmark-simple"
              class="size-5 group-hover:scale-110 transition-transform"
            />
            <span>{t.footer.bookmarks}</span>
          </a>
          <a
            href="https://meowlu.notion.site/ML-12e7c67f7f2d47249f0111882d932663"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center px-4 py-2 gap-3 text-muted-foreground hover:bg-muted transition-colors no-underline group rounded-full"
          >
            <Icon
              name="archive"
              class="size-5 group-hover:scale-110 transition-transform"
            />
            <span>{t.footer.learningLibrary}</span>
          </a>
        </div>
      </div>

      <div>
        <!-- Donate Section -->
        <div class="grid grid-cols-1 xl:grid-cols-2">
          <h4
            class="col-span-1 xl:col-span-2 text-xl text-muted-foreground font-semibold mb-2 px-4"
          >
            {t.footer.donate}
          </h4>
          <a
            href="https://portaly.cc/liang_chin_ml/support"
            target="_blank"
            rel="noopener noreferrer"
            class="col-span-1 flex items-center px-4 py-2 gap-3 text-muted-foreground hover:bg-muted transition-colors no-underline group rounded-full"
          >
            <Icon
              name="wallet"
              class="size-5 group-hover:scale-110 transition-transform"
            />
            <span>{t.footer.portalyDonate}</span>
          </a>
          <a
            href="https://www.buymeacoffee.com/liangchinml"
            target="_blank"
            rel="noopener noreferrer"
            class="col-span-1 flex items-center px-4 py-2 gap-3 text-muted-foreground hover:bg-muted transition-colors no-underline group rounded-full"
          >
            <Icon
              name="coffee"
              class="size-5 group-hover:scale-110 transition-transform"
            />
            <span>Buy Me A Coffee</span>
          </a>
        </div>

        <!-- Connections Section -->
        <div>
          <h4
            class="text-xl text-muted-foreground font-semibold mt-8 mb-2 px-4"
          >
            {t.footer.connections}
          </h4>
          <div class="flex flex-wrap px-1">
            <SocialLinksLite client:load />
          </div>
        </div>

        <div>
          <h4
            class="text-xl text-muted-foreground font-semibold mt-8 mb-2 px-4"
          >
            {t.footer.config}
          </h4>
          <div class="flex flex-wrap gap-4 px-4 pt-1 pb-6">
            <ThemeToggle client:load />
            <LanguageSwitcher locale={locale} />
          </div>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div
      class="py-4 mt-6 bg-muted rounded-md text-muted-foreground text-center text-xs"
    >
      <div class="flex items-center justify-center gap-4 pt-4">
        <div class="w-50 flex items-center justify-end gap-1">
          <span
            role="img"
            aria-label="LuMakes signature"
            class="block h-10 opacity-75 rounded-full bg-foreground"
            style={`width: calc(10 * 100 / 100 * 0.25rem); -webkit-mask: url(${cssUrl(brandFlatLogoImg)}) no-repeat center / contain; mask: url(${cssUrl(brandFlatLogoImg)}) no-repeat center / contain;`}
          ></span>
          <span
            role="img"
            aria-label="LuMakes signature"
            class="block h-9 opacity-75 bg-foreground"
            style={`width: calc(7 * 7208 / 3200 * 0.25rem); -webkit-mask: url(${cssUrl(brandSignUrl)}) no-repeat center / contain; mask: url(${cssUrl(brandSignUrl)}) no-repeat center / contain;`}
          ></span>
        </div>
        <Icon
          name="x"
          class="size-5 group-hover:scale-110 transition-transform"
        />
        <div class="w-50 flex items-center justify-start">
          <span
            role="img"
            aria-label="Liang Chin Lu signature"
            class="mr-auto block h-7 opacity-75 mt-2 bg-foreground"
            style={`width: calc(7 * 2286 / 457 * 0.25rem); -webkit-mask: url(${cssUrl(signUrl)}) no-repeat center / contain; mask: url(${cssUrl(signUrl)}) no-repeat center / contain;`}
          ></span>
        </div>
      </div>

      <p class="mt-6">
        <a
          href={locale === "en" ? "/en/privacy/" : "/privacy/"}
          class="hover:text-foreground underline-offset-4 hover:underline"
          >{t.footer.privacyPolicy}</a
        >
      </p>

      <p class="mt-4">
        {t.footer.copyright}
      </p>
    </div>
  </div>
</footer>
