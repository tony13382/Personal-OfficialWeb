---
import Icon from "@/components/Icon.astro";
import { SocialLinksLite } from "../data/social";
import ThemeToggle from "@/components/ThemeToggle";
import signUrl from "@/assets/imgs/index/sign.svg?url";
---

<footer class="rounded-t-3xl bg-background border-t border-0">
  <div class="max-w-8xl mx-auto px-4 md:px-12 py-8">
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-start"
    >
      <!-- Links Section -->
      <div
        class="grid col-span-1 lg:col-span-2 grid-cols-1 lg:grid-cols-2 gap-8"
      >
        <div class="col-span-1">
          <h4 class="text-xl text-muted-foreground font-semibold mb-2 px-4">
            產品 APPs
          </h4>
          <a
            href="/apps/kit/"
            rel="noopener noreferrer"
            class="flex items-center px-4 py-2 gap-3 text-muted-foreground hover:bg-muted transition-colors no-underline group rounded-full"
          >
            <Icon
              name="book-bookmark"
              class="size-5 group-hover:scale-110 transition-transform"
            />
            <span>Kit・書籤管理工具</span>
          </a>
          <a
            href="/apps/cloudbio/"
            rel="noopener noreferrer"
            class="flex items-center px-4 py-2 gap-3 text-muted-foreground hover:bg-muted transition-colors no-underline group rounded-full"
          >
            <Icon
              name="link"
              class="size-5 group-hover:scale-110 transition-transform"
            />
            <span>CloudBio・Bio Link 工具</span>
          </a>
          <a
            href="/apps/nextags/"
            rel="noopener noreferrer"
            class="flex items-center px-4 py-2 gap-3 text-muted-foreground hover:bg-muted transition-colors no-underline group rounded-full"
          >
            <Icon
              name="playlist"
              class="size-5 group-hover:scale-110 transition-transform"
            />
            <span>NexTags・音樂整理工具</span>
          </a>
          <a
            href="https://stockcal.lumakes.com/"
            rel="noopener noreferrer"
            class="flex items-center px-4 py-2 gap-3 text-muted-foreground hover:bg-muted transition-colors no-underline group rounded-full"
          >
            <Icon
              name="calculator"
              class="size-5 group-hover:scale-110 transition-transform"
            />
            <span>股票試算小工具</span>
          </a>
        </div>
        <div class="col-span-1">
          <h4 class="text-xl text-muted-foreground font-semibold mb-2 px-4">
            連結 Links
          </h4>
          <a
            href="https://go.lumakes.com/learn"
            rel="noopener noreferrer"
            class="flex items-center px-4 py-2 gap-3 text-muted-foreground hover:bg-muted transition-colors no-underline group rounded-full"
          >
            <Icon
              name="graduation-cap"
              class="size-5 group-hover:scale-110 transition-transform"
            />
            <span>知識推薦獲取來源</span>
          </a>
          <a
            href="https://go.lumakes.com/bm"
            rel="noopener noreferrer"
            class="flex items-center px-4 py-2 gap-3 text-muted-foreground hover:bg-muted transition-colors no-underline group rounded-full"
          >
            <Icon
              name="bookmark-simple"
              class="size-5 group-hover:scale-110 transition-transform"
            />
            <span>推薦工作書籤</span>
          </a>
          <a
            href="https://meowlu.notion.site/ML-12e7c67f7f2d47249f0111882d932663"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center px-4 py-2 gap-3 text-muted-foreground hover:bg-muted transition-colors no-underline group rounded-full"
          >
            <Icon
              name="archive"
              class="size-5 group-hover:scale-110 transition-transform"
            />
            <span>學習資源庫</span>
          </a>
        </div>
        <!-- <a
          href="https://www.instagram.com/digi.ocean/?hl=zh-tw"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center px-4 py-2 gap-3 text-muted-foreground hover:bg-muted transition-colors no-underline group rounded-full"
        >
          <InstagramLogoIcon
            className="size-5 group-hover:scale-110 transition-transform"
          />
          <span>知識帳號（DigiOcean）</span>
        </a> -->
      </div>

      <div>
        <!-- Donate Section -->
        <div class="grid grid-cols-1 lg:grid-cols-2">
          <h4
            class="col-span-1 lg:col-span-2 text-xl text-muted-foreground font-semibold mb-2 px-4"
          >
            贊助 Donate
          </h4>
          <a
            href="https://portaly.cc/liang_chin_ml/support"
            target="_blank"
            rel="noopener noreferrer"
            class="col-span-1 flex items-center px-4 py-2 gap-3 text-muted-foreground hover:bg-muted transition-colors no-underline group rounded-full"
          >
            <Icon
              name="wallet"
              class="size-5 group-hover:scale-110 transition-transform"
            />
            <span>Portaly 贊助</span>
          </a>
          <a
            href="https://www.buymeacoffee.com/liangchinml"
            target="_blank"
            rel="noopener noreferrer"
            class="col-span-1 flex items-center px-4 py-2 gap-3 text-muted-foreground hover:bg-muted transition-colors no-underline group rounded-full"
          >
            <Icon
              name="coffee"
              class="size-5 group-hover:scale-110 transition-transform"
            />
            <span>Buy Me A Coffee</span>
          </a>
        </div>

        <!-- Connections Section -->
        <div>
          <h4
            class="text-xl text-muted-foreground font-semibold mt-8 mb-2 px-4"
          >
            聯絡 Connections
          </h4>
          <div class="flex flex-wrap px-1">
            <SocialLinksLite client:load />
          </div>
        </div>

        <div>
          <h4
            class="text-xl text-muted-foreground font-semibold mt-8 mb-2 px-4"
          >
            閱讀設定 Config
          </h4>
          <div class="flex flex-wrap px-4 pt-1">
            <ThemeToggle client:load />
          </div>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div
      class="py-4 mt-6 bg-muted rounded-md text-muted-foreground text-center text-xs"
    >
      <span
        role="img"
        aria-label="Liang Chin Lu signature"
        class="block h-7 opacity-75 mx-auto my-4 bg-foreground"
        style={`width: calc(7 * 2286 / 457 * 0.25rem); -webkit-mask: url(${signUrl}) no-repeat center / contain; mask: url(${signUrl}) no-repeat center / contain;`}
      ></span>

      <p class="mt-6">Copyright © 2026 Liang-Chin, Lu 版權所有</p>
      <p class="mt-2">
        <a
          href="/privacy/"
          class="hover:text-foreground underline-offset-4 hover:underline"
          >隱私權政策</a
        >
      </p>
    </div>
  </div>
</footer>
