---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  galleryId?: string;
  class?: string;
}

const { src, alt, galleryId = "gallery", class: className = "" } = Astro.props;
---

<a
  href={src.src}
  data-fancybox={galleryId}
  aria-label={alt}
  class:list={["block mx-auto cursor-zoom-in", className]}
>
  <Image src={src} alt={alt} loading="lazy" />
</a>
