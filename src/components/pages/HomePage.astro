---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Icon from "@/components/Icon.astro";
import { ProjectsFall } from "@/components/projects/ProjectsFall";
import { Button } from "@/components/ui/button";
import { ProfileCardTigger, ProfileCardModal } from "@/components/data/profile";
import AppCard from "@/components/apps/AppCard.astro";
import ArticleCard from "@/components/articles/ArticleCard.astro";
import { apps } from "@/data/apps";
import { themes } from "@/lib/themes";
import { useTranslations, filterByLocale, type Locale } from "@/i18n";
import { resolveCollectionImages } from "@/lib/resolve-image";
import profileImg from "@/assets/imgs/index/profileAnimate.png";

interface Props {
  locale?: Locale;
}

const { locale = "zh-Hant" } = Astro.props;
const t = useTranslations(locale);
const prefix = locale === "en" ? "/en" : "";

const rawProjects = await getCollection("projects");
const allProjects = resolveCollectionImages(filterByLocale(rawProjects, locale));
const sortedProjects = allProjects.sort((a, b) => {
  if (a.data.pin && !b.data.pin) return -1;
  if (!a.data.pin && b.data.pin) return 1;
  return b.data.startDate.getTime() - a.data.startDate.getTime();
});

const allPosts = await getCollection("articles");
const sortedPosts = filterByLocale(allPosts, locale)
  .sort((a, b) => {
    if (a.data.pin && !b.data.pin) return -1;
    if (!a.data.pin && b.data.pin) return 1;
    return b.data.date.getTime() - a.data.date.getTime();
  })
  .slice(0, 6);
---

<BaseLayout
  title={t.index.title}
  description={t.index.description}
  ogImage="/assets/MetaTagCover.png"
  headerType="main"
  locale={locale}
>
  <div class="min-h-screen pt-20">
    <!-- Hero Section -->
    <section class="relative overflow-hidden">
      <div
        class="absolute inset-0 bg-linear-to-b from-(--theme-primary-5) via-transparent to-transparent"
      >
      </div>
      <div
        class="container mx-auto px-4 pt-24 pb-20 md:pt-40 md:pb-32 relative"
      >
        <div class="max-w-4xl mx-auto text-center">
          <p
            class="text-sm font-medium tracking-widest uppercase text-(--theme-primary) mb-6"
          >
            {t.index.brand}
          </p>
          <h1
            class="text-4xl sm:text-5xl md:text-7xl font-bold mb-8 bg-linear-to-b from-gray-900 via-gray-800 to-gray-400 dark:from-white dark:via-gray-100 dark:to-gray-400 bg-clip-text text-transparent tracking-tight leading-[1.3] md:leading-[1.2]"
          >
            {t.index.heroTitle.split('\n').map((line, i) => (
              <>
                {i > 0 && <br class="hidden sm:block" />}
                {line}
              </>
            ))}
          </h1>
          <p
            class="text-lg md:text-xl text-muted-foreground max-w-xl mx-auto leading-relaxed"
          >
            {t.index.heroSubtitle}
          </p>
          <div class="fade-in flex items-center justify-center gap-4 mt-10">
            <a href={`${prefix}/articles/`}>
              <Button
                className="px-6 py-5 text-base rounded-full dark:bg-foreground text-white dark:text-background dark:opacity-75 dark:hover:opacity-100"
              >
                {t.index.browseArticles}
              </Button>
            </a>
            <a href={`${prefix}/about/`}>
              <Button
                variant="outline"
                className="px-6 py-5 text-base rounded-full"
              >
                {t.index.aboutMe}
              </Button>
            </a>
          </div>
        </div>
      </div>
      <div
        class="absolute bottom-0 left-0 right-0 h-px bg-linear-to-r from-transparent via-border to-transparent"
      >
      </div>
    </section>

    <!-- Personal Intro Section -->
    <section class="relative">
      <div class="container mx-auto px-4 py-16 md:py-20 relative">
        <div class="max-w-3xl mx-auto text-center">
          <p
            class="fade-in text-sm font-medium tracking-widest uppercase text-(--theme-primary) mb-3"
          >
            About
          </p>
          <Image
                src={profileImg}
                alt={`${t.index.aboutSectionTitle}${locale === "en" ? "'s avatar" : "的頭像"}`}
                class="fade-in mx-auto mt-6 mb-4 size-32 rounded-full overflow-hidden"
                width={128}
                height={128}
                loading="eager"
            />
          <h2
            class="fade-in text-2xl md:text-3xl font-bold mb-4 tracking-tight"
          >
            {t.index.aboutSectionTitle}
          </h2>
          <p class="fade-in text-muted-foreground text-lg leading-relaxed">
            {t.index.aboutSectionDescription}
          </p>
        </div>
      </div>
      <div
        class="absolute bottom-0 left-0 right-0 h-px bg-linear-to-r from-transparent via-border to-transparent"
      >
      </div>
    </section>

    <!-- Articles Section -->
    <section class="relative">
      <div
        class="absolute inset-0 bg-linear-to-b from-transparent via-(--theme-primary-5) to-transparent"
      >
      </div>
      <div class="container mx-auto px-4 py-20 md:py-32 relative">
        <div class="max-w-6xl mx-auto">
          <div class="fade-in max-w-2xl mb-12 md:mb-16">
            <p
              class="text-sm font-medium tracking-widest uppercase text-(--theme-primary) mb-3"
            >
              Articles
            </p>
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
              {t.index.articlesSectionTitle}
            </h2>
            <p class="text-muted-foreground text-lg leading-relaxed">
              {t.index.articlesSectionDescription}
            </p>
          </div>
          <div
            class="fade-in grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5"
          >
            {sortedPosts.map((post) => <ArticleCard post={post} />)}
          </div>
          <div class="fade-in mt-10 text-center">
            <a href={`${prefix}/articles/`}>
              <Button
                variant="outline"
                className="px-6 py-5 text-base rounded-full hover:[&>svg]:ms-1"
              >
                {t.common.viewAllArticles}
                <Icon name="arrow-right" class="transition-all duration-300" />
              </Button>
            </a>
          </div>
        </div>
      </div>
      <div
        class="absolute bottom-0 left-0 right-0 h-px bg-linear-to-r from-transparent via-border to-transparent"
      >
      </div>
    </section>

    <!-- APP Section -->
    <section class="relative">
      <div class="container mx-auto px-4 py-20 md:py-32">
        <div class="max-w-6xl mx-auto">
          <div class="fade-in max-w-2xl mb-12 md:mb-16">
            <p
              class="text-sm font-medium tracking-widest uppercase text-(--theme-primary) mb-3"
            >
              Apps
            </p>
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
              {t.index.appsSectionTitle}
            </h2>
            <p class="text-muted-foreground text-lg leading-relaxed">
              {t.index.appsSectionDescription}
            </p>
          </div>
          <div class="fade-in grid grid-cols-1 gap-5">
            {apps.slice(0, 3).map((app) => <AppCard app={app} locale={locale} />)}
          </div>
          <div class="fade-in mt-10 text-center">
            <a href={`${prefix}/apps/`}>
              <Button
                variant="outline"
                className="px-6 py-5 text-base rounded-full hover:[&>svg]:ms-1"
              >
                {t.common.viewAllApps}
                <Icon name="arrow-right" class="transition-all duration-300" />
              </Button>
            </a>
          </div>
        </div>
      </div>
      <div
        class="absolute bottom-0 left-0 right-0 h-px bg-linear-to- from-transparent via-border to-transparent"
      >
      </div>
    </section>

    <!-- Projects Section -->
    <section class="relative">
      <div class="container mx-auto px-4 py-20 md:py-32">
        <div class="max-w-6xl mx-auto">
          <div class="fade-in max-w-2xl mb-12 md:mb-16">
            <p
              class="text-sm font-medium tracking-widest uppercase text-(--theme-primary) mb-3"
            >
              Projects
            </p>
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
              {t.index.projectsSectionTitle}
            </h2>
            <p class="text-muted-foreground text-lg leading-relaxed">
              {t.index.projectsSectionDescription}
            </p>
          </div>
          <div class="fade-in">
            <ProjectsFall
              projects={sortedProjects}
              themes={themes}
              compact
              pathPrefix={prefix}
              locale={locale}
              client:load
            />
          </div>
        </div>
      </div>
    </section>
  </div>

  <ProfileCardTigger client:load />
  <ProfileCardModal client:load />

  <style>
    .fade-in {
      opacity: 0.5;
      transform: translateY(24px);
      transition:
        opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script is:inline>
    function initFadeIn() {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0, rootMargin: "0px 0px -40px 0px" },
      );

      document.querySelectorAll(".fade-in").forEach((el) => {
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight && rect.bottom > 0) {
          el.classList.add("visible");
        } else {
          observer.observe(el);
        }
      });
    }

    initFadeIn();

    window.addEventListener("pageshow", (e) => {
      if (e.persisted) {
        document.querySelectorAll(".fade-in:not(.visible)").forEach((el) => {
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight && rect.bottom > 0) {
            el.classList.add("visible");
          }
        });
        initFadeIn();
      }
    });
  </script>
</BaseLayout>
