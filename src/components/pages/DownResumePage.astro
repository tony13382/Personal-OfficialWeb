---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ResumeTabs } from "@/components/react/ResumeTabs";
import { useTranslations, type Locale } from "@/i18n";

interface Props {
  locale?: Locale;
}

const { locale = "zh-Hant" } = Astro.props;
const t = useTranslations(locale);

// 之後要換履歷檔，把這三個 driveId 換成新的 Google Drive 檔案 ID 即可
const resumes = [
  {
    key: "general" as const,
    label: t.downResume.tabs.general,
    description: t.downResume.descriptions.general,
    driveId: "1n3P8s-PfX53IkA-M1TJiMEifeS_Nx68-",
  },
  // {
  //   key: "dev" as const,
  //   label: t.downResume.tabs.dev,
  //   description: t.downResume.descriptions.dev,
  //   driveId: "REPLACE_WITH_DEV_DRIVE_ID",
  // },
  // {
  //   key: "design" as const,
  //   label: t.downResume.tabs.design,
  //   description: t.downResume.descriptions.design,
  //   driveId: "REPLACE_WITH_DESIGN_DRIVE_ID",
  // },
];
---

<BaseLayout
  title={t.downResume.title}
  description={t.downResume.description}
  headerType="project"
  locale={locale}
>
  <div
    class="relative pt-20 pb-8 w-full bg-[linear-gradient(135deg,#e5e7eb_0%,#d1d5db_50%,#9ca3af_100%)] dark:bg-[linear-gradient(135deg,#27272a_0%,#18181b_50%,#0a0a0a_100%)]"
  >
    <div class="relative flex items-center py-8 w-full min-h-24">
      <div class="container grid grid-cols-1 mx-auto">
        <div class="flex flex-col gap-3">
          <h1
            class="px-3 text-4xl text-center font-bold text-gray-900 dark:text-gray-100"
          >
            {t.downResume.heading}
          </h1>
          <p class="text-center text-gray-700 dark:text-gray-300">
            {t.downResume.subheading}
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="min-h-screen bg-linear-to-b from-muted/30 to-transparent">
    <section class="container mx-auto px-4 py-12">
      <div class="max-w-3xl mx-auto">
        <article class="bg-background rounded-2xl border p-6 md:p-10">
          <ResumeTabs
            client:load
            resumes={resumes}
            defaultKey="general"
            openInNewTabLabel={t.downResume.openInNewTab}
            downloadLabel={t.downResume.download}
            mobileHint={t.downResume.mobileHint}
          />
        </article>
      </div>
    </section>
  </div>
</BaseLayout>
