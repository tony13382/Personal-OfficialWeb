---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { ProfileCardModal, profileData } from "@/components/data/profile";
import profileImg from "@/assets/imgs/index/profileAnimate.png";
import Icon from "@/components/Icon.astro";
import ArticleCard from "@/components/articles/ArticleCard.astro";
import {
  Pagination,
  PaginationContent,
  PaginationItem,
  PaginationLink,
  PaginationNext,
  PaginationPrevious,
} from "@/components/ui/pagination";
import { useTranslations, filterByLocale, type Locale } from "@/i18n";
import { absolutize, buildItemListJsonLd } from "@/lib/structured-data";
import { themes } from "@/lib/themes";

interface Props {
  locale?: Locale;
}

const { locale = "zh-Hant" } = Astro.props;
const t = useTranslations(locale);

const PAGE_SIZE = 12;

const allPosts = await getCollection("articles");
const localePosts = filterByLocale(allPosts, locale);
const sortedPosts = localePosts.sort((a, b) => {
  if (a.data.pin && !b.data.pin) return -1;
  if (!a.data.pin && b.data.pin) return 1;
  return b.data.date.getTime() - a.data.date.getTime();
});

const totalPages = Math.max(1, Math.ceil(sortedPosts.length / PAGE_SIZE));
const pageNumbers = Array.from({ length: totalPages }, (_, i) => i + 1);

const categories = [...new Set(sortedPosts.map((p) => p.data.category))];
const tabs = [
  { key: "all", label: t.articles.allLabel },
  ...categories.map((c) => ({ key: c, label: c })),
];

const localePrefix = locale === "en" ? "/en" : "";
const pageQuery = (page: number) => `?p=${page}`;

const siteUrl =
  Astro.site?.toString().replace(/\/$/, "") || "https://lumakes.com";
const listUrl = `${siteUrl}${localePrefix}/articles/`;

const articlesItemList = buildItemListJsonLd({
  name: t.articles.heading,
  description: t.articles.subtitle,
  url: listUrl,
  locale,
  siteId: `${siteUrl}/#website`,
  authorId: `${siteUrl}/#person`,
  items: sortedPosts.map((post) => ({
    type: "BlogPosting" as const,
    url: `${siteUrl}${localePrefix}/articles/${post.slug}/`,
    name: post.data.title,
    description: post.data.description,
    ...(post.data.cover ? { image: absolutize(siteUrl, post.data.cover) } : {}),
    datePublished: post.data.date.toISOString(),
    ...(post.data.updatedDate
      ? { dateModified: post.data.updatedDate.toISOString() }
      : {}),
  })),
});
---

<BaseLayout
  title={t.articles.title}
  description={t.articles.description}
  headerType="main"
  locale={locale}
  themeColor={themes.pink.primary}
  themeColorDark={themes.pink.darkPrimary}
  pageJsonLd={articlesItemList}
>
  <div class="min-h-screen pt-20">
    <section class="relative overflow-hidden">
      <div
        class="absolute inset-0 bg-gradient-to-b from-[var(--theme-primary-5)] via-transparent to-transparent"
      >
      </div>
      <div
        class="container mx-auto px-4 pt-24 pb-20 md:pt-40 md:pb-32 relative"
      >
        <div class="max-w-4xl mx-auto text-center">
          <p
            class="text-sm font-medium tracking-widest uppercase text-[var(--theme-primary)] mb-6"
          >
            Articles
          </p>
          <h1
            class="text-4xl sm:text-5xl md:text-7xl font-bold mb-8 bg-gradient-to-b from-gray-900 via-gray-800 to-gray-400 dark:from-white dark:via-gray-100 dark:to-gray-400 bg-clip-text text-transparent tracking-tight leading-[1.3] md:leading-[1.2]"
          >
            {t.articles.heading}
          </h1>
          <p
            class="text-lg md:text-xl text-muted-foreground max-w-xl mx-auto leading-relaxed"
          >
            {t.articles.subtitle}
          </p>
        </div>
      </div>
      <div
        class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"
      >
      </div>
    </section>

    <section class="relative" data-articles-section>
      <div
        class="absolute inset-0 bg-gradient-to-b from-transparent via-[var(--theme-primary-5)] to-transparent"
      >
      </div>
      <div class="container mx-auto px-4 py-20 md:py-32 relative">
        <div class="max-w-6xl mx-auto">
          <div
            class="fade-in flex flex-wrap justify-center gap-2 mb-10"
            data-filter-bar
          >
            {
              tabs.map((tab) => (
                <button
                  type="button"
                  data-filter-btn
                  data-category={tab.key}
                  class="px-4 py-1.5 text-sm font-medium rounded-full border transition-all cursor-pointer data-[active=true]:bg-[var(--theme-primary)] data-[active=true]:text-white data-[active=true]:border-[var(--theme-primary)] data-[active=false]:text-muted-foreground data-[active=false]:bg-card data-[active=false]:border-border data-[active=false]:hover:border-[var(--theme-primary)] data-[active=false]:hover:text-[var(--theme-primary)] data-[active=false]:hover:shadow-sm"
                >
                  {tab.label}
                </button>
              ))
            }
          </div>

          <div class="fade-in">
            <div
              class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
              data-card-grid
            >
              {
                sortedPosts.map((post, index) => {
                  const cardPage = Math.floor(index / PAGE_SIZE) + 1;
                  return (
                    <ArticleCard
                      post={post}
                      locale={locale}
                      data-card
                      data-category={post.data.category}
                      data-page={cardPage}
                      class={cardPage === 1 ? "" : "hidden"}
                    />
                  );
                })
              }
            </div>

            <div class="hidden text-center py-12" data-empty-state>
              <Icon
                name="toolbox"
                class="size-16 mx-auto mb-4 text-muted-foreground/50"
              />
              <p class="text-muted-foreground">
                {t.articles.noArticlesInCategory}
              </p>
            </div>

            {
              totalPages > 1 && (
                <Pagination className="mt-10" data-pagination>
                  <PaginationContent>
                    <PaginationItem>
                      <PaginationPrevious
                        href={pageQuery(1)}
                        data-pagination-prev
                        data-disabled="true"
                        aria-label={t.articles.prevPage}
                        aria-disabled="true"
                      >
                        <span>{t.articles.prevPage}</span>
                      </PaginationPrevious>
                    </PaginationItem>

                    {pageNumbers.map((p) => (
                      <PaginationItem>
                        <PaginationLink
                          href={pageQuery(p)}
                          data-pagination-link
                          data-page={p}
                          data-active={String(p === 1)}
                          aria-current={p === 1 ? "page" : undefined}
                          aria-label={t.articles.pageLabel.replace(
                            "{page}",
                            String(p),
                          )}
                        >
                          {p}
                        </PaginationLink>
                      </PaginationItem>
                    ))}

                    <PaginationItem>
                      <PaginationNext
                        href={pageQuery(2)}
                        data-pagination-next
                        data-disabled={String(totalPages <= 1)}
                        aria-label={t.articles.nextPage}
                      >
                        <span>{t.articles.nextPage}</span>
                      </PaginationNext>
                    </PaginationItem>
                  </PaginationContent>
                </Pagination>
              )
            }
          </div>

          {
            sortedPosts.length === 0 && (
              <div class="text-center py-12">
                <Icon
                  name="toolbox"
                  class="size-16 mx-auto mb-4 text-muted-foreground/50"
                />
                <p class="text-muted-foreground">{t.articles.noArticles}</p>
              </div>
            )
          }
        </div>
      </div>
    </section>
  </div>

  <style>
    .fade-in {
      opacity: 0.5;
      transform: translateY(24px);
      transition:
        opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }
    [data-pagination-link][data-active="true"] {
      border-width: 1px;
      border-color: hsl(var(--input));
      background-color: hsl(var(--background));
    }
    [data-pagination-prev][data-disabled="true"],
    [data-pagination-next][data-disabled="true"] {
      pointer-events: none;
      opacity: 0.4;
    }
  </style>

  <button
    id="profile-modal-btn"
    class="floatbtn fixed bottom-28 right-6 size-16 md:bottom-30 md:right-8 rounded-full flex items-center justify-center shadow-[0_4px_12px_rgba(0,0,0,0.15)] opacity-0 invisible transition-all duration-300 ease-in-out z-40 cursor-pointer hover:-translate-y-1 hover:shadow-[0_6px_16px_rgba(0,0,0,0.2)] active:-translate-y-0.5"
    title={profileData.name}
  >
    <Image
      src={profileImg}
      alt={profileData.name}
      class="size-16 rounded-full overflow-hidden"
      width={128}
      height={128}
    />
  </button>

  <ProfileCardModal client:load />

  <script is:inline>
    function initFadeIn() {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0, rootMargin: "0px 0px -40px 0px" },
      );

      document.querySelectorAll(".fade-in").forEach((el) => {
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight && rect.bottom > 0) {
          el.classList.add("visible");
        } else {
          observer.observe(el);
        }
      });
    }

    initFadeIn();

    window.addEventListener("pageshow", (e) => {
      if (e.persisted) {
        document.querySelectorAll(".fade-in:not(.visible)").forEach((el) => {
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight && rect.bottom > 0) {
            el.classList.add("visible");
          }
        });
        initFadeIn();
      }
    });
  </script>

  <script is:inline define:vars={{ totalPages: totalPages }}>
    (function () {
      const buttons = Array.from(
        document.querySelectorAll("[data-filter-btn]"),
      );
      const cards = Array.from(document.querySelectorAll("[data-card]"));
      const pagination = document.querySelector("[data-pagination]");
      const pageLinks = Array.from(
        document.querySelectorAll("[data-pagination-link]"),
      );
      const prevLink = document.querySelector("[data-pagination-prev]");
      const nextLink = document.querySelector("[data-pagination-next]");
      const emptyState = document.querySelector("[data-empty-state]");
      const grid = document.querySelector("[data-card-grid]");
      const section = document.querySelector("[data-articles-section]");

      let activeCategory = "all";
      let activePage = readPageFromURL();

      function readPageFromURL() {
        const raw = new URLSearchParams(window.location.search).get("p");
        const num = Number(raw);
        if (Number.isInteger(num) && num >= 1 && num <= totalPages) return num;
        return 1;
      }

      function buildHref(page) {
        const url = new URL(window.location.href);
        if (page === 1) url.searchParams.delete("p");
        else url.searchParams.set("p", String(page));
        return url.pathname + (url.search || "") + url.hash;
      }

      function render() {
        let matchCount = 0;

        cards.forEach((card) => {
          const cat = card.getAttribute("data-category");
          const cardPage = Number(card.getAttribute("data-page"));
          const matches = activeCategory === "all" || cat === activeCategory;
          if (!matches) {
            card.classList.add("hidden");
            return;
          }
          matchCount++;
          if (activeCategory === "all" && cardPage !== activePage) {
            card.classList.add("hidden");
          } else {
            card.classList.remove("hidden");
          }
        });

        if (pagination) {
          pagination.classList.toggle("hidden", activeCategory !== "all");
        }

        pageLinks.forEach((link) => {
          const page = Number(link.getAttribute("data-page"));
          const isActive = page === activePage;
          link.setAttribute("data-active", String(isActive));
          if (isActive) link.setAttribute("aria-current", "page");
          else link.removeAttribute("aria-current");
          link.setAttribute("href", buildHref(page));
        });

        if (prevLink) {
          const disabled = activePage <= 1;
          prevLink.setAttribute("data-disabled", String(disabled));
          prevLink.setAttribute(
            "href",
            buildHref(Math.max(1, activePage - 1)),
          );
          if (disabled) prevLink.setAttribute("aria-disabled", "true");
          else prevLink.removeAttribute("aria-disabled");
        }

        if (nextLink) {
          const disabled = activePage >= totalPages;
          nextLink.setAttribute("data-disabled", String(disabled));
          nextLink.setAttribute(
            "href",
            buildHref(Math.min(totalPages, activePage + 1)),
          );
          if (disabled) nextLink.setAttribute("aria-disabled", "true");
          else nextLink.removeAttribute("aria-disabled");
        }

        if (emptyState && grid) {
          const isEmpty = matchCount === 0;
          emptyState.classList.toggle("hidden", !isEmpty);
          grid.classList.toggle("hidden", isEmpty);
        }
      }

      function goToPage(page, options) {
        const opts = options || {};
        const next = Math.min(Math.max(1, page), totalPages);
        if (next === activePage && !opts.force) return;
        activePage = next;
        if (opts.updateHistory !== false) {
          const href = buildHref(next);
          window.history.pushState({ p: next }, "", href);
        }
        render();
        if (opts.scroll && section) {
          const top =
            section.getBoundingClientRect().top + window.scrollY - 80;
          window.scrollTo({ top, behavior: "smooth" });
        }
      }

      buttons.forEach((btn) => {
        btn.setAttribute(
          "data-active",
          String(btn.getAttribute("data-category") === activeCategory),
        );
        btn.addEventListener("click", () => {
          const next = btn.getAttribute("data-category");
          if (next === activeCategory) return;
          activeCategory = next;
          buttons.forEach((b) => {
            b.setAttribute(
              "data-active",
              String(b.getAttribute("data-category") === activeCategory),
            );
          });
          render();
        });
      });

      pageLinks.forEach((link) => {
        link.addEventListener("click", (e) => {
          e.preventDefault();
          const page = Number(link.getAttribute("data-page"));
          goToPage(page, { scroll: true });
        });
      });

      if (prevLink) {
        prevLink.addEventListener("click", (e) => {
          e.preventDefault();
          if (prevLink.getAttribute("data-disabled") === "true") return;
          goToPage(activePage - 1, { scroll: true });
        });
      }

      if (nextLink) {
        nextLink.addEventListener("click", (e) => {
          e.preventDefault();
          if (nextLink.getAttribute("data-disabled") === "true") return;
          goToPage(activePage + 1, { scroll: true });
        });
      }

      window.addEventListener("popstate", () => {
        activePage = readPageFromURL();
        render();
      });

      render();
    })();
  </script>
</BaseLayout>
