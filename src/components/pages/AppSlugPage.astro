---
import "@/styles/global.css";
import Header from "@/components/header/Header.astro";
import { themes } from "@/lib/themes";
import NexTagsLanding from "@/components/apps/nextags/Landing";
import { getHtmlLang, type Locale } from "@/i18n";
import { getAppName, getAppDescription, type AppInfo } from "@/data/apps";

interface Props {
  app: AppInfo;
  locale?: Locale;
}

const { app, locale = "zh-Hant" } = Astro.props;
const htmlLang = getHtmlLang(locale);
const prefix = locale === "en" ? "/en" : "";
const appName = getAppName(app, locale);
const appDesc = getAppDescription(app, locale);
const themeColors = themes.natural;
const isPageMode = app.mode === "page";

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || "http://localhost:4321",
);
---

<!doctype html>
<html lang={htmlLang} class="bg-background">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{appName} - {appDesc}</title>
    <meta name="description" content={appDesc} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${appName} - ${appDesc}`} />
    <meta property="og:description" content={appDesc} />
    <meta property="og:locale" content={locale === "en" ? "en_US" : "zh_TW"} />
    <meta property="og:site_name" content={locale === "en" ? "LuMakes" : "亮點創研 LuMakes"} />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-165132NHTH"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-165132NHTH");
    </script>

    <style
      define:vars={{
        "theme-primary": themeColors.primary,
        "theme-secondary": themeColors.secondary,
      }}
    ></style>
  </head>
  <body
    class:list={[
      "font-sans bg-background m-0 flex flex-col",
      isPageMode ? "min-h-dvh" : "overflow-hidden h-dvh",
    ]}
  >
    <Header
      type="app"
      themeColor={themeColors.primary}
      appName={appName}
      projectHref={app.projectSlug
        ? `${prefix}/projects/${app.projectSlug}/`
        : undefined}
      appUrl={app.url}
      locale={locale}
    />
    {
      isPageMode && app.slug === "nextags" ? (
        <div class="flex-1 pt-18">
          <NexTagsLanding client:load />
        </div>
      ) : (
        <div class="flex-1 pt-18">
          <iframe
            src={app.url}
            title={appName}
            class="w-full h-full border-0"
            allow="clipboard-read; clipboard-write"
          />
        </div>
      )
    }
  </body>
</html>
