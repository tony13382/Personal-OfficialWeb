---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { useTranslations, type Locale } from "@/i18n";

interface Props {
  locale?: Locale;
}

const { locale = "zh-Hant" } = Astro.props;
const t = useTranslations(locale);

const lastUpdated = "2026-04-13";
---

<BaseLayout
  title={t.privacy.title}
  description={t.privacy.description}
  headerType="project"
  locale={locale}
>
  <div
    class="relative pt-20 pb-8 w-full bg-[linear-gradient(135deg,#e5e7eb_0%,#d1d5db_50%,#9ca3af_100%)] dark:bg-[linear-gradient(135deg,#27272a_0%,#18181b_50%,#0a0a0a_100%)]"
  >
    <div class="relative flex items-center py-8 w-full min-h-24">
      <div class="container grid grid-cols-1 mx-auto">
        <div class="flex flex-col gap-3">
          <h1
            class="px-3 text-4xl text-center font-bold text-gray-900 dark:text-gray-100"
          >
            {t.privacy.heading}
          </h1>
          <p class="text-center text-gray-700 dark:text-gray-300">
            {t.privacy.lastUpdated.replace('{date}', lastUpdated)}
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="min-h-screen bg-linear-to-b from-muted/30 to-transparent">
    <section class="container mx-auto px-4 py-12">
      <div class="max-w-3xl mx-auto">
        <article
          class="bg-background rounded-2xl border p-8 md:p-12 space-y-10 leading-relaxed text-foreground"
        >
          <section class="space-y-3">
            <p>{t.privacy.intro}</p>
          </section>

          <section class="space-y-3">
            <h2 class="text-2xl font-bold">{t.privacy.section1Title}</h2>
            <p>{t.privacy.section1Intro}</p>
            <ul class="list-disc pl-6 space-y-2">
              {t.privacy.section1Items.map((item) => <li>{item}</li>)}
            </ul>
            <p>{t.privacy.section1Note}</p>
          </section>

          <section class="space-y-3">
            <h2 class="text-2xl font-bold">{t.privacy.section2Title}</h2>
            <p>{t.privacy.section2Intro}</p>
            <ul class="list-disc pl-6 space-y-2">
              {t.privacy.section2Items.map((item) => <li>{item}</li>)}
            </ul>
            <p>{t.privacy.section2Note}</p>
          </section>

          <section class="space-y-3">
            <h2 class="text-2xl font-bold">{t.privacy.section3Title}</h2>
            <p>{t.privacy.section3Intro}</p>
            <ul class="list-disc pl-6 space-y-2">
              <li>
                Google Privacy Policy: <a
                  href="https://policies.google.com/privacy"
                  target="_blank"
                  rel="noopener noreferrer"
                  >https://policies.google.com/privacy</a
                >
              </li>
              <li>
                Google Analytics Terms of Service: <a
                  href="https://marketingplatform.google.com/about/analytics/terms/tw/"
                  target="_blank"
                  rel="noopener noreferrer"
                  >https://marketingplatform.google.com/about/analytics/terms/tw/</a
                >
              </li>
            </ul>
            <p>
              {t.privacy.section3Cloudflare}
              <a
                href="https://www.cloudflare.com/privacypolicy/"
                target="_blank"
                rel="noopener noreferrer">{t.privacy.section3CloudflareLink}</a
              >。
            </p>
          </section>

          <section class="space-y-3">
            <h2 class="text-2xl font-bold">{t.privacy.section4Title}</h2>
            <p>{t.privacy.section4Intro}</p>
            <p>{t.privacy.section4Control}</p>
            <ul class="list-disc pl-6 space-y-2">
              {t.privacy.section4Items.map((item) => <li>{item}</li>)}
              <li>
                <a
                  href="https://tools.google.com/dlpage/gaoptout"
                  target="_blank"
                  rel="noopener noreferrer"
                  >{locale === "en" ? "Install the " : "安裝 "}<span>{t.privacy.section4GAOptout}</span></a
                >{t.privacy.section4GAOptoutSuffix}
              </li>
            </ul>
          </section>

          <section class="space-y-3">
            <h2 class="text-2xl font-bold">{t.privacy.section5Title}</h2>
            <p>{t.privacy.section5Content}</p>
          </section>

          <section class="space-y-3">
            <h2 class="text-2xl font-bold">{t.privacy.section6Title}</h2>
            <p>{t.privacy.section6Intro}</p>
            <ul class="list-disc pl-6 space-y-2">
              {t.privacy.section6Items.map((item) => <li>{item}</li>)}
            </ul>
            <p>{t.privacy.section6Note}</p>
          </section>

          <section class="space-y-3">
            <h2 class="text-2xl font-bold">{t.privacy.section7Title}</h2>
            <p>{t.privacy.section7Content}</p>
          </section>

          <section class="space-y-3">
            <h2 class="text-2xl font-bold">{t.privacy.section8Title}</h2>
            <p>{t.privacy.section8Content}</p>
          </section>

          <section class="space-y-3">
            <h2 class="text-2xl font-bold">{t.privacy.section9Title}</h2>
            <p>{t.privacy.section9Content}</p>
          </section>
        </article>
      </div>
    </section>
  </div>
</BaseLayout>
