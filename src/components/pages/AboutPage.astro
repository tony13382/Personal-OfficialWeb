---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { themes } from "@/lib/themes";
import Icon from "@/components/Icon.astro";
import { JobsFall } from "@/components/jobs/JobsFall";
import { ProjectsFall } from "@/components/projects/ProjectsFall";
import { Button } from "@/components/ui/button";
import { Card, CardContent } from "@/components/ui/card";
import { SocialLinksLite } from "@/components/data/social";
import { ActionBtnLinks } from "@/components/data/actionBtn";
import {
  profileDataZh,
  profileDataEn,
  ProfileCardModal,
} from "@/components/data/profile";
import {
  certifications,
  issuerLabels,
  issuerOrder,
  type IssuerKey,
} from "@/components/data/certifications";
import { Image } from "astro:assets";
import myHeadImg from "@/assets/imgs/index/myHead.webp";
import profileImg from "@/assets/imgs/index/profileAnimate.png";
import { useTranslations, filterByLocale, type Locale } from "@/i18n";
import { resolveCollectionImages } from "@/lib/resolve-image";
import {
  CaretDownIcon,
  CaretLeftIcon,
  CaretRightIcon,
} from "@phosphor-icons/react/dist/ssr";

interface Props {
  locale?: Locale;
}

const { locale = "zh-Hant" } = Astro.props;
const t = useTranslations(locale);
const prefix = locale === "en" ? "/en" : "";
const dateLocale = locale === "en" ? "en-US" : "zh-TW";
const profile = locale === "en" ? profileDataEn : profileDataZh;

const rawJobs = await getCollection("jobs");
const allJobs = resolveCollectionImages(filterByLocale(rawJobs, locale));
const sortedJobs = allJobs.sort((a, b) => {
  const aIsActive = !a.data.endDate;
  const bIsActive = !b.data.endDate;

  if (aIsActive && !bIsActive) return -1;
  if (!aIsActive && bIsActive) return 1;

  const aDate = a.data.startDate?.getTime() || 0;
  const bDate = b.data.startDate?.getTime() || 0;
  return bDate - aDate;
});

const rawProjects = await getCollection("projects");
const allProjects = resolveCollectionImages(
  filterByLocale(rawProjects, locale),
);
const sortedProjects = allProjects.sort((a, b) => {
  if (a.data.pin && !b.data.pin) return -1;
  if (!a.data.pin && b.data.pin) return 1;
  return b.data.startDate.getTime() - a.data.startDate.getTime();
});
const awardProjects = allProjects
  .filter((project) => project.data.scores && project.data.scores.length > 0)
  .sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime());

const ANTHROPIC_PREVIEW_COUNT = 6;

const certGroups = issuerOrder
  .map((issuer) => ({
    issuer,
    items: certifications
      .filter((c) => c.issuer === issuer)
      .sort((a, b) => b.issuedDate.localeCompare(a.issuedDate)),
  }))
  .filter((group) => group.items.length > 0);

function formatIssuedDate(isoYearMonth: string, loc: Locale): string {
  const [y, m] = isoYearMonth.split("-").map(Number);
  const date = new Date(y, (m || 1) - 1);
  return date.toLocaleDateString(loc === "en" ? "en-US" : "zh-TW", {
    year: "numeric",
    month: "long",
  });
}
---

<BaseLayout
  title={t.about.title}
  description={t.about.description}
  ogImage="/assets/MetaTagCover.png"
  headerType="main"
  locale={locale}
>
  <div
    class="min-h-screen bg-linear-to-b from-gray-50 to-transparent dark:from-transparent pt-20"
  >
    <!-- Hero Section -->
    <section class="container mx-auto px-1 md:px-4 pt-16 md:pt-24">
      <div class="max-w-6xl mx-auto text-center">
        <div class="grid items-center px-2">
          <p
            class="text-sm font-medium tracking-widest uppercase text-(--theme-primary) mb-4"
          >
            {locale === "en" ? "LuMakes" : "亮點創研 LuMakes"}
          </p>
          <h1
            class="text-5xl md:text-6xl font-bold mb-6 bg-linear-to-r from-gray-900 to-gray-600 dark:from-white dark:to-gray-400 bg-clip-text text-transparent tracking-wider leading-normal"
          >
            {t.about.heroTitle}
          </h1>
          <div class="overflow-hidden">
            <div class="overflow-hidden">
              <Card
                className="max-w-80 mt-12 hover:mt-9 pb-4 hover:pb-7 inline-flex rounded-b-none transition-all duration-300 dark:border dark:border-border dark:bg-transparent"
              >
                <CardContent className="gap-6 items-center pt-3 pb-4">
                  <div
                    class="h-4 w-10 my-2 border rounded-full bg-(--theme-primary-10) inset-shadow-sm"
                  >
                  </div>
                  <Image
                    src={myHeadImg}
                    alt={`${profile.name}${locale === "en" ? "'s avatar" : "的頭像"}`}
                    class="size-32 rounded-full overflow-hidden"
                    width={128}
                    height={128}
                    loading="eager"
                  />
                  <div class="px-4">
                    <p
                      class="text-xl md:text-2xl text-foreground font-bold mb-3"
                    >
                      {profile.name}
                    </p>
                    <p class="text-muted-foreground mb-3">
                      {profile.jobTitle}
                    </p>
                  </div>
                  <ActionBtnLinks client:load />
                  <div>
                    <div class="flex px-1">
                      <SocialLinksLite client:load />
                    </div>
                  </div>
                </CardContent>
              </Card>
            </div>
            <div class="h-1 border-t"></div>
          </div>
        </div>
      </div>

      <!-- 工作經歷 -->
      <section class="container mx-auto px-4 py-12">
        <div class="max-w-6xl mx-auto space-y-16">
          <div class="grid gap-4">
            <h2 class="text-3xl font-bold">{t.about.workExperience}</h2>
            <JobsFall
              jobs={sortedJobs.slice(0, 3)}
              themes={themes}
              pathPrefix={prefix}
              locale={locale}
            />
            {
              sortedJobs.length > 3 && (
                <div data-expand-section>
                  <div class="hidden" data-expand-content>
                    <JobsFall
                      jobs={sortedJobs.slice(3)}
                      themes={themes}
                      pathPrefix={prefix}
                      locale={locale}
                    />
                  </div>
                  <Button variant="outline" data-expand-btn>
                    {t.common.showMoreCount.replace(
                      "{count}",
                      String(sortedJobs.length),
                    )}
                  </Button>
                </div>
              )
            }
          </div>
          <div class="grid gap-4">
            <h2 class="text-3xl font-bold pb-8 -mb-6">
              {t.about.projectWorks}
            </h2>
            <!-- 專案作品 -->
            <div class="max-w-6xl mx-auto">
              <ProjectsFall
                projects={sortedProjects}
                themes={themes}
                pathPrefix={prefix}
                locale={locale}
                client:load
              />
            </div>
          </div>

          <!-- 得獎紀錄 -->
          <div class="grid gap-4">
            <h2 class="text-3xl font-bold">{t.about.awards}</h2>
            {
              awardProjects.length === 0 ? (
                <div class="text-center py-12">
                  <Icon
                    name="trophy"
                    class="size-16 mx-auto mb-4 text-muted-foreground/50"
                  />
                  <p class="text-muted-foreground">{t.about.noAwards}</p>
                </div>
              ) : (
                <Fragment>
                  <div class="space-y-6">
                    {awardProjects.slice(0, 3).map((project) => {
                      const themeColors = themes[project.data.theme];
                      return (
                        <Card
                          className="shadow-none border"
                          data-card-theme
                          style={
                            {
                              "--card-primary-light": themeColors.primary,
                              "--card-primary-dark": themeColors.darkPrimary,
                            } as React.CSSProperties
                          }
                        >
                          <CardContent className="gap-4">
                            <div class="flex">
                              <div class="flex-1 grid">
                                <h3
                                  class="text-xl font-bold mb-2"
                                  style="color: var(--card-primary)"
                                >
                                  {project.data.title}
                                </h3>
                                <p class="text-sm text-muted-foreground">
                                  {project.data.startDate.toLocaleDateString(
                                    dateLocale,
                                    { year: "numeric", month: "long" },
                                  )}
                                  {project.data.endDate
                                    ? ` - ${project.data.endDate.toLocaleDateString(dateLocale, { year: "numeric", month: "long" })}`
                                    : ` - ${t.common.now}`}
                                </p>
                              </div>
                              <a href={`${prefix}/projects/${project.slug}/`}>
                                <Button variant="outline">
                                  {t.common.viewProject}
                                </Button>
                              </a>
                            </div>
                            <hr />
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                              {project.data.scores.map((score) => (
                                <div class="flex items-start gap-3">
                                  <div class="flex-1">
                                    <div class="flex items-baseline gap-2 flex-wrap">
                                      <span class="text-xl font-semibold text-foreground">
                                        {score.award}
                                      </span>
                                      {score.category && (
                                        <span class="text-sm text-muted-foreground">
                                          ({score.category})
                                        </span>
                                      )}
                                    </div>
                                    <p class="text-sm text-muted-foreground mt-1">
                                      {score.title}
                                    </p>
                                  </div>
                                </div>
                              ))}
                            </div>
                          </CardContent>
                        </Card>
                      );
                    })}
                  </div>
                  {awardProjects.length > 3 && (
                    <div data-expand-section>
                      <div class="hidden space-y-6 mt-6" data-expand-content>
                        {awardProjects.slice(3).map((project) => {
                          const themeColors = themes[project.data.theme];
                          return (
                            <Card className="shadow-none border">
                              <CardContent className="gap-4">
                                <div class="flex">
                                  <div class="flex-1 grid">
                                    <h3
                                      class="text-xl font-bold mb-2"
                                      style={`color: ${themeColors.primary}`}
                                    >
                                      {project.data.title}
                                    </h3>
                                    <p class="text-sm text-muted-foreground">
                                      {project.data.startDate.toLocaleDateString(
                                        dateLocale,
                                        { year: "numeric", month: "long" },
                                      )}
                                      {project.data.endDate
                                        ? ` - ${project.data.endDate.toLocaleDateString(dateLocale, { year: "numeric", month: "long" })}`
                                        : ` - ${t.common.now}`}
                                    </p>
                                  </div>
                                  <a
                                    href={`${prefix}/projects/${project.slug}/`}
                                  >
                                    <Button variant="outline">
                                      {t.common.viewProject}
                                    </Button>
                                  </a>
                                </div>
                                <hr />
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                  {project.data.scores.map((score) => (
                                    <div class="flex items-start gap-3">
                                      <div class="flex-1">
                                        <div class="flex items-baseline gap-2 flex-wrap">
                                          <span class="text-xl font-semibold text-foreground">
                                            {score.award}
                                          </span>
                                          {score.category && (
                                            <span class="text-sm text-muted-foreground">
                                              ({score.category})
                                            </span>
                                          )}
                                        </div>
                                        <p class="text-sm text-muted-foreground mt-1">
                                          {score.title}
                                        </p>
                                      </div>
                                    </div>
                                  ))}
                                </div>
                              </CardContent>
                            </Card>
                          );
                        })}
                      </div>
                      <Button variant="outline" data-expand-btn>
                        {t.common.showMoreCount.replace(
                          "{count}",
                          String(awardProjects.length),
                        )}
                        <CaretDownIcon className="size-4" />
                      </Button>
                    </div>
                  )}
                </Fragment>
              )
            }
          </div>

          <!-- 資格認證 -->
          <div class="grid gap-4">
            <h2 class="text-3xl font-bold">{t.about.certifications}</h2>
            <div class="space-y-10">
              {
                certGroups.map((group) => {
                  const label = issuerLabels[group.issuer as IssuerKey][locale];
                  const total = group.items.length;
                  const pageSize = ANTHROPIC_PREVIEW_COUNT;
                  const totalPages = Math.ceil(total / pageSize);
                  const useSlider = total > pageSize;
                  const pages = Array.from({ length: totalPages }, (_, i) =>
                    group.items.slice(i * pageSize, (i + 1) * pageSize),
                  );
                  const renderCard = (
                    cert: (typeof group.items)[number],
                  ) => (
                    <a
                      href={cert.credentialUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group block h-full"
                    >
                      <Card className="shadow-none border h-full transition-colors group-hover:border-(--theme-primary) hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
                        <CardContent className="flex flex-col h-full gap-3 p-4">
                          <p class="text-sm text-muted-foreground">
                            {formatIssuedDate(cert.issuedDate, locale)}
                          </p>
                          <p class="font-bold text-foreground transition-colors group-hover:text-(--theme-primary)">
                            {cert.name}
                          </p>
                          {cert.skills[locale].length > 0 && (
                            <div class="flex flex-wrap gap-1.5 mt-auto pt-1">
                              {cert.skills[locale].map((skill) => (
                                <span class="text-xs px-2 py-0.5 rounded-full bg-muted text-muted-foreground">
                                  {skill}
                                </span>
                              ))}
                            </div>
                          )}
                        </CardContent>
                      </Card>
                    </a>
                  );
                  return (
                    <div>
                      <div class="flex items-baseline justify-between flex-wrap gap-2 mb-4">
                        <h3 class="text-xl font-bold">{label}</h3>
                        <span class="text-sm text-muted-foreground">
                          {t.about.certificationsCount.replace(
                            "{count}",
                            String(total),
                          )}
                        </span>
                      </div>
                      {useSlider ? (
                        <Fragment>
                          <div class="md:hidden" data-expand-section>
                            <div class="grid grid-cols-1 gap-4 [grid-auto-rows:1fr]">
                              {group.items
                                .slice(0, pageSize)
                                .map((cert) => renderCard(cert))}
                            </div>
                            <div class="hidden mt-4" data-expand-content>
                              <div class="grid grid-cols-1 gap-4 [grid-auto-rows:1fr]">
                                {group.items
                                  .slice(pageSize)
                                  .map((cert) => renderCard(cert))}
                              </div>
                            </div>
                            <div class="mt-4 flex justify-center">
                              <Button variant="outline" data-expand-btn>
                                {t.about.showAllCertifications.replace(
                                  "{count}",
                                  String(total),
                                )}
                                <CaretDownIcon className="size-4" />
                              </Button>
                            </div>
                          </div>
                          <div class="hidden md:block" data-cert-slider>
                            <div class="overflow-hidden">
                              <div
                                class="flex items-stretch transition-transform duration-300 ease-out"
                                data-cert-track
                              >
                                {pages.map((items) => (
                                  <div class="shrink-0 w-full grid grid-cols-2 lg:grid-cols-3 gap-4 [grid-auto-rows:1fr]">
                                    {items.map((cert) => renderCard(cert))}
                                  </div>
                                ))}
                              </div>
                            </div>
                            <div class="flex items-center justify-between gap-3 mt-4">
                              <Button
                                variant="outline"
                                size="icon"
                                data-cert-prev
                                disabled
                                aria-label={t.articles.prevPage}
                              >
                                <CaretLeftIcon className="size-4" />
                              </Button>
                              <span class="text-sm text-muted-foreground tabular-nums">
                                <span data-cert-current>1</span> / {totalPages}
                              </span>
                              <Button
                                variant="outline"
                                size="icon"
                                data-cert-next
                                aria-label={t.articles.nextPage}
                              >
                                <CaretRightIcon className="size-4" />
                              </Button>
                            </div>
                          </div>
                        </Fragment>
                      ) : (
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 [grid-auto-rows:1fr]">
                          {group.items.map((cert) => renderCard(cert))}
                        </div>
                      )}
                    </div>
                  );
                })
              }
            </div>
          </div>
        </div>
      </section>
    </section>

    <button
      id="profile-modal-btn"
      class="floatbtn fixed bottom-28 right-6 size-16 md:bottom-30 md:right-8 rounded-full bg-(--theme-primary) text-background flex items-center justify-center shadow-[0_4px_12px_rgba(0,0,0,0.15)] opacity-0 invisible transition-all duration-300 ease-in-out z-40 cursor-pointer hover:bg-(--theme-secondary) hover:-translate-y-1 hover:shadow-[0_6px_16px_rgba(0,0,0,0.2)] active:-translate-y-0.5"
      title={profile.name}
    >
      <Image
        src={profileImg}
        alt={`${profile.name}${locale === "en" ? "'s avatar" : "的頭像"}`}
        class="size-16 rounded-full overflow-hidden"
        width={128}
        height={128}
      />
    </button>

    <ProfileCardModal client:load />
  </div>

  <script>
    document.querySelectorAll("[data-expand-section]").forEach((section) => {
      const btn = section.querySelector("[data-expand-btn]");
      const content = section.querySelector("[data-expand-content]");
      btn?.addEventListener("click", () => {
        content?.classList.remove("hidden");
        btn.remove();
      });
    });

    document.querySelectorAll("[data-cert-slider]").forEach((slider) => {
      const track = slider.querySelector<HTMLElement>("[data-cert-track]");
      const prev = slider.querySelector<HTMLButtonElement>("[data-cert-prev]");
      const next = slider.querySelector<HTMLButtonElement>("[data-cert-next]");
      const current = slider.querySelector<HTMLElement>("[data-cert-current]");
      if (!track || !prev || !next || !current) return;
      const totalPages = track.children.length;
      let index = 0;

      const update = () => {
        track.style.transform = `translateX(-${index * 100}%)`;
        current.textContent = String(index + 1);
        prev.disabled = index === 0;
        next.disabled = index >= totalPages - 1;
      };

      prev.addEventListener("click", () => {
        if (index > 0) {
          index -= 1;
          update();
        }
      });
      next.addEventListener("click", () => {
        if (index < totalPages - 1) {
          index += 1;
          update();
        }
      });

      update();
    });
  </script>
</BaseLayout>
