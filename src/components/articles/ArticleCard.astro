---
import { Card } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import type { CollectionEntry } from "astro:content";
import type { Locale } from "@/i18n";

type ArticlePost = CollectionEntry<"articles">;

interface Props extends astroHTML.JSX.HTMLAttributes {
  post: ArticlePost;
  class?: string;
  locale?: Locale;
}

const { post, class: className, locale = "zh-Hant", ...rest } = Astro.props;
const prefix = locale === "en" ? "/en" : "";
const updatedLabel = locale === "en" ? "Updated" : "已更新";

const pad = (n: number) => String(n).padStart(2, "0");
const formatDateCompact = (d: Date) =>
  `${pad(d.getFullYear() % 100)}.${pad(d.getMonth() + 1)}.${pad(d.getDate())}`;

const RECENT_UPDATE_DAYS = 60;
const isRecentlyUpdated = post.data.updatedDate
  ? (Date.now() - post.data.updatedDate.getTime()) / 86400000 <=
    RECENT_UPDATE_DAYS
  : false;
---

<a
  href={`${prefix}/articles/${post.slug}/`}
  class:list={["group block no-underline", className]}
  {...rest}
>
  <Card
    className="shadow-none border hover:shadow-xl transition-all duration-300 hover:-translate-y-1 overflow-hidden h-full flex flex-col bg-background/80 backdrop-blur-sm"
  >
    {
      post.data.cover && (
        <div class="aspect-[1200/630] overflow-hidden">
          <img
            src={post.data.cover}
            alt={post.data.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
            decoding="async"
          />
        </div>
      )
    }
    <div class="flex flex-col gap-1.5 p-5 flex-1">
      <h3
        class="text-lg font-bold group-hover:text-[var(--theme-primary)] transition-colors leading-snug"
      >
        {post.data.title}
      </h3>
      <p
        class="mb-3 text-sm text-muted-foreground line-clamp-2 leading-relaxed"
      >
        {post.data.description}
      </p>
      <div class="flex items-center gap-2 flex-wrap mt-auto pt-3 border-t">
        <span class="text-sm text-[var(--theme-primary)]">
          {post.data.category}
        </span>
        <div class="flex-1 flex items-center justify-end gap-2">
          {
            isRecentlyUpdated && (
              <Badge variant="outline" className="text-[10px] px-2 py-0">
                {updatedLabel}
              </Badge>
            )
          }
        </div>
        <time
          class="text-sm text-muted-foreground tabular-nums"
          datetime={post.data.date.toISOString()}
        >
          {formatDateCompact(post.data.date)}
        </time>
      </div>
    </div>
  </Card>
</a>
