---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ProjectsFall } from "@/components/projects/ProjectsFall";
import { themes } from "@/lib/themes";
import { ProfileCardModal, profileData } from "@/components/data/profile";
import { Image } from "astro:assets";
import profileImg from "@/assets/imgs/index/profileAnimate.png";

const allProjects = await getCollection("projects");
// 按 pin 和日期排序
const sortedProjects = allProjects.sort((a, b) => {
  if (a.data.pin && !b.data.pin) return -1;
  if (!a.data.pin && b.data.pin) return 1;
  return b.data.startDate.getTime() - a.data.startDate.getTime();
});
---

<BaseLayout
  title="呂亮進・一位多領域背景的產品創造者"
  description="關於呂亮進 - AI 工程師、產品設計師、全端開發者"
  ogImage="/assets/MetaTagCover.png"
  headerType="main"
>
  <div class="min-h-screen pt-20">
    <!-- Hero Section -->
    <section class="relative overflow-hidden">
      <div
        class="absolute inset-0 bg-gradient-to-b from-[var(--theme-primary-5)] via-transparent to-transparent"
      >
      </div>
      <div
        class="container mx-auto px-4 pt-24 pb-20 md:pt-40 md:pb-32 relative"
      >
        <div class="max-w-4xl mx-auto text-center">
          <p
            class="fade-in text-sm font-medium tracking-widest uppercase text-[var(--theme-primary)] mb-6"
          >
            Projects
          </p>
          <h1
            class="fade-in text-4xl sm:text-5xl md:text-7xl font-bold mb-8 bg-gradient-to-b from-gray-900 via-gray-800 to-gray-400 dark:from-white dark:via-gray-100 dark:to-gray-400 bg-clip-text text-transparent tracking-tight leading-[1.3] md:leading-[1.2]"
          >
            專案作品
          </h1>
          <p
            class="fade-in text-lg md:text-xl text-muted-foreground max-w-xl mx-auto leading-relaxed"
          >
            從構想到落地的完整紀錄，涵蓋 AI 應用、產品設計與全端開發
          </p>
        </div>
      </div>
      <div
        class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"
      >
      </div>
    </section>

    <!-- Projects Section -->
    <section class="relative">
      <div
        class="absolute inset-0 bg-gradient-to-b from-transparent via-[var(--theme-primary-5)] to-transparent"
      >
      </div>
      <div class="container mx-auto px-4 py-20 md:py-32 relative">
        <div class="max-w-6xl mx-auto">
          <div class="fade-in">
            <ProjectsFall projects={sortedProjects} themes={themes} client:load />
          </div>
        </div>
      </div>
    </section>
  </div>

  <style>
    .fade-in {
      opacity: 0;
      transform: translateY(24px);
      transition:
        opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
    );
    document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
  </script>
  <button
    id="profile-modal-btn"
    class="floatbtn fixed bottom-28 right-6 size-16 md:bottom-30 md:right-8 rounded-full bg-[var(--theme-primary)] text-background flex items-center justify-center shadow-[0_4px_12px_rgba(0,0,0,0.15)] opacity-0 invisible transition-all duration-300 ease-in-out z-40 cursor-pointer hover:bg-[var(--theme-secondary)] hover:-translate-y-1 hover:shadow-[0_6px_16px_rgba(0,0,0,0.2)] active:-translate-y-0.5 lg:hidden"
    title="通知我"
  >
    <Image
      src={profileImg}
      alt={`${profileData.name}的頭像`}
      class="size-16 rounded-full overflow-hidden"
      width={128}
      height={128}
    />
  </button>

  <ProfileCardModal client:load />
</BaseLayout>
