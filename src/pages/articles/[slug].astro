---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Card, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { ProfileCardModal, profileData } from "@/components/data/profile";
import { Image } from "astro:assets";
import profileImg from "@/assets/imgs/index/profileAnimate.png";

export async function getStaticPaths() {
  const posts = await getCollection("articles");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

// 只取 h1, h2 做大綱
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

const seo = {
  title: post.data.seo?.metaTitle || `${post.data.title}・亮點創研 LuMakes`,
  description: post.data.seo?.metaDescription || post.data.description,
  ogImage: post.data.seo?.ogImage || post.data.cover,
};
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  ogImage={seo.ogImage}
  headerType="project"
>
  <!-- Hero Section -->
  <div
    class="relative pt-20 pb-8 w-full bg-[linear-gradient(135deg,_#e5e7eb_0%,_#d1d5db_50%,_#9ca3af_100%)] dark:bg-[linear-gradient(135deg,_#27272a_0%,_#18181b_50%,_#0a0a0a_100%)]"
  >
    <div class="relative flex items-center py-8 w-full min-h-24">
      <div class="container grid grid-cols-1 mx-auto">
        <div class="flex flex-col gap-3">
          <div class="flex justify-center">
            <Badge
              variant="outline"
              className="bg-black/10 text-gray-900 border-gray-900/20 dark:bg-white/10 dark:text-gray-100 dark:border-white/20"
              >{post.data.category}</Badge
            >
          </div>
          <h1
            class="px-3 text-4xl text-center font-bold text-gray-900 dark:text-gray-100"
          >
            {post.data.title}
          </h1>
          <p class="px-3 text-center text-gray-700 dark:text-gray-300">
            {post.data.description}
          </p>
        </div>
      </div>
    </div>
  </div>

  <div
    class="min-h-screen bg-gradient-to-t from-muted/30 dark:from-muted/10 to-transparent"
  >
    <section class="container mx-auto px-4 py-12">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-12 gap-8">
          <!-- Main Content (left on lg) -->
          <div class="col-span-12 lg:col-span-8 grid gap-8">
            <!-- Cover Image -->
            {
              post.data.cover && (
                <Card className="overflow-hidden">
                  <div class="aspect-[1200/630]">
                    <img
                      src={post.data.cover}
                      alt={post.data.title}
                      class="w-full h-full object-cover"
                      width="1200"
                      height="630"
                      loading="eager"
                      decoding="async"
                    />
                  </div>
                </Card>
              )
            }

            <!-- MDX Content - will be split into cards per H2 section -->
            <article
              id="article-content"
              data-pagefind-body
              data-pagefind-meta="type:文章"
              class="flex flex-col gap-2 min-w-0"
            >
              <Content />
            </article>
          </div>

          <!-- Sidebar: TOC (right on lg) -->
          <div class="hidden lg:block col-span-4 relative">
            <div class="sticky top-24">
              <Card>
                <CardContent className="space-y-3">
                  <p class="text-sm font-bold text-foreground">目錄</p>
                  <nav
                    id="toc-nav"
                    class="grid gap-0.5 max-h-[60vh] overflow-y-auto"
                  >
                    {
                      tocHeadings.map((heading) => (
                        <a
                          href={`#${heading.slug}`}
                          class:list={[
                            "toc-link block py-1 text-sm no-underline rounded-md transition-all duration-200",
                            heading.depth === 2
                              ? "ps-3 font-medium text-muted-foreground hover:text-foreground"
                              : "ps-6 text-muted-foreground/70 hover:text-muted-foreground",
                          ]}
                          data-slug={heading.slug}
                        >
                          {heading.text}
                        </a>
                      ))
                    }
                  </nav>

                  <hr />

                  <!-- Tags -->
                  {
                    post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1.5">
                        {post.data.tags.map((tag: string) => (
                          <Badge variant="secondary" className="text-xs">
                            {tag}
                          </Badge>
                        ))}
                      </div>
                    )
                  }

                  <!-- Date -->
                  <div class="mt-4 text-xs text-muted-foreground space-y-1">
                    <p>
                      發佈於{" "}
                      {
                        post.data.date.toLocaleDateString("zh-TW", {
                          year: "numeric",
                          month: "long",
                          day: "numeric",
                        })
                      }
                    </p>
                    {
                      post.data.updatedDate && (
                        <p>
                          更新於{" "}
                          {post.data.updatedDate.toLocaleDateString("zh-TW", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                          })}
                        </p>
                      )
                    }
                  </div>
                </CardContent>
              </Card>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Mobile TOC Button -->
  <button
    id="mobile-toc-btn"
    class="floatbtn fixed bottom-8 left-6 size-16 md:bottom-8 md:left-8 rounded-full bg-background text-foreground border border-border hover:bg-muted flex items-center justify-center shadow-[0_4px_12px_rgba(0,0,0,0.08)] opacity-0 invisible transition-all duration-300 ease-in-out z-40 cursor-pointer hover:-translate-y-1 hover:shadow-[0_6px_16px_rgba(0,0,0,0.12)] active:-translate-y-0.5 lg:hidden"
    title="目錄"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 256 256"
      fill="currentColor"
      class="size-7"
    >
      <path
        d="M228,128a8,8,0,0,1-8,8H40a8,8,0,0,1,0-16H220A8,8,0,0,1,228,128ZM40,72H220a8,8,0,0,0,0-16H40a8,8,0,0,0,0,16ZM220,184H40a8,8,0,0,0,0,16H220a8,8,0,0,0,0-16Z"
      ></path>
    </svg>
  </button>

  <!-- Mobile TOC Modal -->
  <div id="mobile-toc-modal" class="fixed inset-0 z-50 hidden lg:hidden">
    <div id="mobile-toc-overlay" class="absolute inset-0 bg-black/50"></div>
    <div
      class="absolute bottom-0 left-0 right-0 max-h-[70vh] bg-background rounded-t-2xl overflow-hidden animate-slide-up"
    >
      <div class="flex items-center justify-between p-4 border-b">
        <p class="text-sm font-bold">目錄</p>
        <button
          id="mobile-toc-close"
          class="text-muted-foreground hover:text-foreground cursor-pointer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 256 256"
            fill="currentColor"
            class="size-5"
          >
            <path
              d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"
            ></path>
          </svg>
        </button>
      </div>
      <nav class="p-4 overflow-y-auto max-h-[60vh] grid gap-0.5">
        {
          tocHeadings.map((heading) => (
            <a
              href={`#${heading.slug}`}
              class:list={[
                "mobile-toc-link block py-2 text-sm no-underline rounded-md transition-all duration-200",
                heading.depth === 2
                  ? "ps-3 font-medium text-foreground"
                  : "ps-6 text-muted-foreground",
              ]}
              data-slug={heading.slug}
            >
              {heading.text}
            </a>
          ))
        }
      </nav>
    </div>
  </div>

  <button
    id="profile-modal-btn"
    class="floatbtn fixed bottom-28 right-6 size-16 md:bottom-30 md:right-8 rounded-full bg-[var(--theme-primary)] text-background flex items-center justify-center shadow-[0_4px_12px_rgba(0,0,0,0.15)] opacity-0 invisible transition-all duration-300 ease-in-out z-40 cursor-pointer hover:bg-[var(--theme-secondary)] hover:-translate-y-1 hover:shadow-[0_6px_16px_rgba(0,0,0,0.2)] active:-translate-y-0.5"
    title="通知我"
  >
    <Image
      src={profileImg}
      alt={`${profileData.name}的頭像`}
      class="size-16 rounded-full overflow-hidden"
      width={128}
      height={128}
    />
  </button>

  <ProfileCardModal client:load />

  <!-- Scrollspy Script -->
  <script>
    function initScrollspy() {
      const tocLinks =
        document.querySelectorAll<HTMLAnchorElement>(".toc-link");
      if (tocLinks.length === 0) return;

      const headingEls: HTMLElement[] = [];
      tocLinks.forEach((link) => {
        const slug = link.dataset.slug;
        if (slug) {
          const el = document.getElementById(slug);
          if (el) headingEls.push(el);
        }
      });

      if (headingEls.length === 0) return;

      const ACTIVE_CLASS = "toc-active";

      function setActive(slug: string) {
        tocLinks.forEach((link) => {
          if (link.dataset.slug === slug) {
            link.classList.add(ACTIVE_CLASS);
            link.scrollIntoView({ block: "nearest", behavior: "smooth" });
          } else {
            link.classList.remove(ACTIVE_CLASS);
          }
        });
      }

      const observer = new IntersectionObserver(
        (entries) => {
          // Find the first visible heading
          for (const entry of entries) {
            if (entry.isIntersecting) {
              setActive(entry.target.id);
              return;
            }
          }
        },
        {
          rootMargin: "-80px 0px -60% 0px",
          threshold: 0,
        },
      );

      headingEls.forEach((el) => observer.observe(el));

      // Set initial active based on scroll position
      const scrollY = window.scrollY + 100;
      let currentSlug = headingEls[0]?.id;
      for (const el of headingEls) {
        if (el.offsetTop <= scrollY) {
          currentSlug = el.id;
        }
      }
      if (currentSlug) setActive(currentSlug);
    }

    initScrollspy();

    // Prevent TOC links from polluting browser history
    document
      .querySelectorAll<HTMLAnchorElement>(".toc-link, .mobile-toc-link")
      .forEach((link) => {
        link.addEventListener("click", (e) => {
          e.preventDefault();
          const slug = link.dataset.slug;
          if (!slug) return;
          const target = document.getElementById(slug);
          if (target) {
            target.scrollIntoView({ behavior: "smooth" });
            history.replaceState(null, "", `#${slug}`);
          }
        });
      });

    // Mobile TOC Modal
    const tocBtn = document.getElementById("mobile-toc-btn");
    const tocModal = document.getElementById("mobile-toc-modal");
    const tocOverlay = document.getElementById("mobile-toc-overlay");
    const tocClose = document.getElementById("mobile-toc-close");
    const mobileTocLinks =
      document.querySelectorAll<HTMLAnchorElement>(".mobile-toc-link");

    function openTocModal() {
      tocModal?.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    }

    function closeTocModal() {
      tocModal?.classList.add("hidden");
      document.body.style.overflow = "";
    }

    tocBtn?.addEventListener("click", openTocModal);
    tocOverlay?.addEventListener("click", closeTocModal);
    tocClose?.addEventListener("click", closeTocModal);
    mobileTocLinks.forEach((link) => {
      link.addEventListener("click", closeTocModal);
    });

    // Split article content by H2 into separate cards
    const article = document.getElementById("article-content");
    if (article) {
      const children = Array.from(article.childNodes);
      const sections: Node[][] = [];
      let current: Node[] = [];

      children.forEach((node) => {
        if (node instanceof HTMLElement && node.tagName === "H2") {
          if (current.length > 0) {
            sections.push(current);
          }
          current = [node];
        } else {
          current.push(node);
        }
      });
      if (current.length > 0) {
        sections.push(current);
      }

      // Clear article and rebuild with cards
      article.innerHTML = "";
      article.classList.remove("gap-2");
      article.classList.add("gap-8");

      sections.forEach((nodes) => {
        // Skip sections that only contain empty text nodes or whitespace
        const hasContent = nodes.some(
          (node) =>
            node instanceof HTMLElement ||
            (node.textContent && node.textContent.trim() !== ""),
        );
        if (!hasContent) return;

        const card = document.createElement("div");
        card.className =
          "rounded-2xl bg-card text-card-foreground shadow-md overflow-hidden";

        const cardContent = document.createElement("div");
        cardContent.className =
          "p-6 flex flex-col gap-2 min-w-0 overflow-hidden";

        nodes.forEach((node) => cardContent.appendChild(node));
        card.appendChild(cardContent);
        article.appendChild(card);
      });
    }

    // Code block copy buttons + collapsible long code blocks
    const LINE_THRESHOLD = 10;

    document.querySelectorAll("article pre").forEach((pre) => {
      const wrapper = document.createElement("div");
      wrapper.className = "code-block-wrapper";
      pre.parentNode?.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      // Copy button
      const copyIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor"><path d="M216,32H88a8,8,0,0,0-8,8V80H40a8,8,0,0,0-8,8V216a8,8,0,0,0,8,8H168a8,8,0,0,0,8-8V176h40a8,8,0,0,0,8-8V40A8,8,0,0,0,216,32ZM160,208H48V96H160Zm48-48H176V88a8,8,0,0,0-8-8H96V48H208Z"/></svg>`;
      const checkIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor"><path d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z"/></svg>`;
      const btn = document.createElement("button");
      btn.className = "code-copy-btn";
      btn.innerHTML = copyIcon;
      btn.addEventListener("click", () => {
        const code =
          pre.querySelector("code")?.textContent || pre.textContent || "";
        navigator.clipboard.writeText(code.trim()).then(() => {
          btn.innerHTML = checkIcon;
          setTimeout(() => {
            btn.innerHTML = copyIcon;
          }, 2000);
        });
      });
      wrapper.appendChild(btn);

      // Collapsible for long code blocks
      const codeEl = pre.querySelector("code") || pre;
      const lineCount = (codeEl.textContent || "").split("\n").length;
      if (lineCount > LINE_THRESHOLD) {
        wrapper.classList.add("code-collapsed");

        const expandBtn = document.createElement("button");
        expandBtn.className = "code-expand-btn";
        expandBtn.textContent = `View all (${lineCount} lines)`;
        expandBtn.addEventListener("click", () => {
          wrapper.classList.remove("code-collapsed");
          expandBtn.remove();
        });
        pre.appendChild(expandBtn);
      }
    });
  </script>

  <style>
    .toc-active {
      color: var(--theme-primary) !important;
      background: var(--theme-primary-10);
      font-weight: 600;
    }

    article :global(h2),
    article :global(h3),
    article :global(h4) {
      scroll-margin-top: 6rem;
    }

    article :global(h2) {
      color: var(--foreground);
    }

    article :global(h2),
    article :global(h3),
    article :global(h4) {
      display: flex;
      align-items: center;
      gap: 0.375rem;
    }

    article :global(h2) {
      margin-top: 0;
      margin-bottom: 0.75rem;
    }

    article :global(h3) {
      margin-top: 1.75rem;
      margin-bottom: 0.25rem;
    }

    article :global(h2 + h3) {
      margin-top: 0.25rem;
    }

    article :global(h4) {
      margin-top: 0.5rem;
      padding-top: 1rem;
      border-top: 1px rgb(233, 233, 233) solid;
      font-weight: 700;
    }

    article :global(h2 svg) {
      width: 1.5rem;
      height: 1.5rem;
      flex-shrink: 0;
    }

    article :global(h3 svg) {
      width: 1.375rem;
      height: 1.375rem;
      flex-shrink: 0;
    }

    article :global(h4 svg) {
      width: 1.25rem;
      height: 1.25rem;
      flex-shrink: 0;
    }

    article :global(p) {
      margin-top: 0.25rem;
      margin-bottom: 0.25rem;
    }

    article :global(ul) {
      list-style-type: disc;
      padding-left: 1.5rem;
    }

    article :global(ol) {
      list-style-type: decimal;
      padding-left: 1.5rem;
    }

    article :global(li) {
      margin: 0.125rem 0;
      padding-left: 0.25rem;
    }

    article :global(li:not(:last-child)) {
      padding-bottom: 0.25rem;
    }

    article :global(code) {
      font-family:
        ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
      font-size: 0.875em;
      font-weight: 500;
      color: #e11d48;
      margin: 0 2px;
      padding: 0.125rem 0.375rem;
      background: #f3f4f6;
      border-radius: 0.25rem;
    }

    :global(.dark) article :global(code) {
      color: #fb7185;
      background: #27272a;
    }

    article :global(pre code),
    :global(.dark) article :global(pre code) {
      font-size: inherit;
      font-weight: inherit;
      color: inherit;
      margin: 0;
      padding: 0;
      background: none;
      border-radius: 0;
    }

    article :global(img) {
      margin-top: 0.5rem;
      margin-bottom: 0.5rem;
      border-radius: 0.75rem;
    }

    :global(.dark) article :global(img) {
      filter: brightness(0.9);
    }

    article :global(.youtube) {
      margin-top: 0.5rem;
      margin-bottom: 0.5rem;
      border-radius: 0.75rem;
    }

    article :global(p a:not(.official-link)) {
      color: var(--theme-primary);
      text-decoration: underline;
      text-underline-offset: 2px;
      transition: opacity 0.2s;
    }

    article :global(p a:not(.official-link):hover) {
      opacity: 0.7;
    }

    article :global(a.official-link) {
      display: flex;
      align-items: center;
      align-self: stretch;
      justify-content: center;
      gap: 0.25rem;
      padding: 0.5rem 0.75rem;
      margin-bottom: 0rem;
      font-weight: 500;
      color: #f6f7f9;
      background: #1e2227;
      border: 1px solid transparent;
      border-radius: 9999px;
      text-decoration: none;
      transition: all 0.2s;
    }

    article :global(a.official-link:hover) {
      color: #ffffff;
      background: #1d1f23;
    }

    :global(.dark) article :global(a.official-link) {
      border-color: rgba(255, 255, 255, 0.12);
    }

    :global(.dark) article :global(a.official-link:hover) {
      border-color: rgba(255, 255, 255, 0.2);
    }

    article :global(span.pricing-tag) {
      display: inline-flex;
      align-items: center;
      align-self: stretch;
      justify-content: center;
      padding: 0.25rem 0.75rem;
      margin-top: 0.5rem;
      margin-bottom: 0rem;
      font-size: 0.75rem;
      font-weight: 500;
      color: #059669;
      background: #ecfdf5;
      border: 1px solid #a7f3d0;
      border-radius: 9999px;
    }

    :global(.dark) article :global(span.pricing-tag) {
      color: #6ee7b7;
      background: rgba(6, 78, 59, 0.35);
      border-color: rgba(16, 185, 129, 0.35);
    }

    article :global(span.pricing-tag.paid) {
      color: #d97706;
      background: #fffbeb;
      border-color: #fde68a;
    }

    :global(.dark) article :global(span.pricing-tag.paid) {
      color: #fcd34d;
      background: rgba(120, 53, 15, 0.35);
      border-color: rgba(217, 119, 6, 0.35);
    }

    article :global(span.pricing-tag.freemium) {
      color: #2563eb;
      background: #eff6ff;
      border-color: #bfdbfe;
    }

    :global(.dark) article :global(span.pricing-tag.freemium) {
      color: #93c5fd;
      background: rgba(30, 58, 138, 0.35);
      border-color: rgba(59, 130, 246, 0.35);
    }

    article :global(h3 span.pricing-tag) {
      font-size: 0.65rem;
      padding: 0.15rem 0.5rem;
      vertical-align: middle;
      margin-top: 0;
    }

    article :global(.or-divider) {
      text-align: center;
      color: #aaa;
      font-size: 0.75rem;
      margin: 0rem 0.25rem 0rem 0.25rem;
    }

    article :global(.callout) {
      position: relative;
      padding: 0.75rem 1rem 0.75rem 1.25rem;
      border-radius: 0.75rem;
      font-size: 0.875rem;
      line-height: 1.6;
      margin: 0.5rem 0;
      overflow: hidden;
    }

    article :global(.callout::before) {
      content: "";
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 6px;
    }

    article :global(.callout.info) {
      background: #eff6ff;
      color: #1e40af;
    }

    :global(.dark) article :global(.callout.info) {
      background: rgba(30, 58, 138, 0.25);
      color: #bfdbfe;
    }

    article :global(.callout.info::before) {
      background: #3b82f6;
    }

    article :global(.callout.warning) {
      background: #fff1f2;
      color: #9f1239;
    }

    :global(.dark) article :global(.callout.warning) {
      background: rgba(136, 19, 55, 0.3);
      color: #fecdd3;
    }

    article :global(.callout.warning::before) {
      background: #fb7185;
    }

    article :global(table) {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
      margin: 0.5rem 0;
    }

    article :global(th) {
      text-align: left;
      padding: 0.625rem 0.75rem;
      border-bottom: 2px solid var(--color-border);
      font-weight: 600;
      color: var(--color-foreground);
    }

    article :global(td) {
      padding: 0.625rem 0.75rem;
      border-bottom: 1px solid var(--color-border);
      color: var(--color-foreground);
    }

    article :global(tr:last-child td) {
      border-bottom: none;
    }

    article :global(p.code-title) {
      margin-bottom: -0.75rem;
      padding: 0.375rem 0.75rem;
      font-size: 0.75rem;
      color: #999;
      background: #282c34;
      border-radius: 0.75rem 0.75rem 0 0;
      border-bottom: 1px solid #3a3f4b;
    }

    article :global(p.code-title + div.code-block-wrapper pre),
    article :global(p.code-title + pre) {
      border-radius: 0 0 0.75rem 0.75rem !important;
    }

    :global(.code-block-wrapper) {
      position: relative;
