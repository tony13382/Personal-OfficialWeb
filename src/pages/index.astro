---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { themes } from "@/lib/themes";
import Icon from "@/components/Icon.astro";
import { ProjectsFall } from "@/components/projects/ProjectsFall";
import { Button } from "@/components/ui/button";
import { Card } from "@/components/ui/card";
import { ProfileCardTigger, ProfileCardModal } from "@/components/data/profile";

const allProjects = await getCollection("projects");
const sortedProjects = allProjects.sort((a, b) => {
  if (a.data.pin && !b.data.pin) return -1;
  if (!a.data.pin && b.data.pin) return 1;
  return b.data.startDate.getTime() - a.data.startDate.getTime();
});

const allPosts = await getCollection("articles");
const sortedPosts = allPosts
  .sort((a, b) => {
    if (a.data.pin && !b.data.pin) return -1;
    if (!a.data.pin && b.data.pin) return 1;
    return b.data.date.getTime() - a.data.date.getTime();
  })
  .slice(0, 6);
---

<BaseLayout
  title="呂亮進・結合 AI 技術與設計思維的全端工程師"
  description="那些我實際在用的工具跟工作流程 — 不只分享用什麼，也聊聊怎麼搭配最順手"
  ogImage="/assets/MetaTagCover.png"
  headerType="main"
>
  <div class="min-h-screen pt-20">
    <!-- Hero Section -->
    <section class="relative overflow-hidden">
      <div
        class="absolute inset-0 bg-gradient-to-b from-[var(--theme-primary-5)] via-transparent to-transparent"
      >
      </div>
      <div
        class="container mx-auto px-4 pt-24 pb-20 md:pt-40 md:pb-32 relative"
      >
        <div class="max-w-4xl mx-auto text-center">
          <p
            class="fade-in text-sm font-medium tracking-widest uppercase text-[var(--theme-primary)] mb-6"
          >
            Tools & Workflow
          </p>
          <h1
            class="fade-in text-4xl sm:text-5xl md:text-7xl font-bold mb-8 bg-gradient-to-b from-gray-900 via-gray-800 to-gray-400 bg-clip-text text-transparent tracking-tight leading-[1.3] md:leading-[1.2]"
          >
            那些我實際在用的<br class="hidden sm:block" />工具跟工作流程
          </h1>
          <p
            class="fade-in text-lg md:text-xl text-muted-foreground max-w-xl mx-auto leading-relaxed"
          >
            不只分享用什麼，也聊聊怎麼搭配最順手
          </p>
          <div class="fade-in flex items-center justify-center gap-4 mt-10">
            <a href="/articles/">
              <Button
                className="px-6 py-5 text-base rounded-full bg-[var(--theme-primary)] hover:bg-[var(--theme-secondary)] text-white"
              >
                瀏覽文章
              </Button>
            </a>
            <a href="/about/">
              <Button
                variant="outline"
                className="px-6 py-5 text-base rounded-full"
              >
                認識我
              </Button>
            </a>
          </div>
        </div>
      </div>
      <div
        class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"
      >
      </div>
    </section>

    <!-- Toolbox Section -->
    <section class="relative">
      <div
        class="absolute inset-0 bg-gradient-to-b from-transparent via-[var(--theme-primary-5)] to-transparent"
      >
      </div>
      <div class="container mx-auto px-4 py-20 md:py-32 relative">
        <div class="max-w-6xl mx-auto">
          <div class="fade-in max-w-2xl mb-12 md:mb-16">
            <p
              class="text-sm font-medium tracking-widest uppercase text-[var(--theme-primary)] mb-3"
            >
              Toolbox
            </p>
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
              分享專欄
            </h2>
            <p class="text-muted-foreground text-lg leading-relaxed">
              用過才推薦的工具組合，附上選擇理由跟實際搭配方式
            </p>
          </div>
          <div
            class="fade-in grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"
          >
            {
              sortedPosts.map((post) => (
                <a
                  href={`/articles/${post.slug}/`}
                  class="group block no-underline"
                >
                  <Card className="shadow-none border hover:shadow-xl transition-all duration-300 hover:-translate-y-1 overflow-hidden h-full bg-background/80 backdrop-blur-sm">
                    {post.data.cover && (
                      <div class="aspect-[1200/630] overflow-hidden">
                        <img
                          src={post.data.cover}
                          alt={post.data.title}
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                          loading="lazy"
                          decoding="async"
                        />
                      </div>
                    )}
                    <div class="grid gap-1.5 p-5">
                      <div class="flex items-center gap-2">
                        <time class="text-sm text-muted-foreground">
                          {post.data.date.toLocaleDateString("zh-TW", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                          })}
                        </time>
                        {post.data.updatedDate && (
                          <span class="text-xs text-muted-foreground">
                            （已更新）
                          </span>
                        )}
                      </div>
                      <h3 class="text-lg font-bold group-hover:text-[var(--theme-primary)] transition-colors leading-snug">
                        {post.data.title}
                      </h3>
                      <p class="text-sm text-muted-foreground line-clamp-2 leading-relaxed">
                        {post.data.description}
                      </p>
                    </div>
                  </Card>
                </a>
              ))
            }
          </div>
          <div class="fade-in mt-10 text-center">
            <a href="/articles/">
              <Button
                variant="outline"
                className="px-6 py-5 text-base rounded-full hover:[&>svg]:ms-1"
              >
                查看所有文章
                <Icon name="arrow-right" class="transition-all duration-300" />
              </Button>
            </a>
          </div>
        </div>
      </div>
      <div
        class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"
      >
      </div>
    </section>

    <!-- Projects Section -->
    <section class="relative">
      <div class="container mx-auto px-4 py-20 md:py-32">
        <div class="max-w-6xl mx-auto">
          <div class="fade-in max-w-2xl mb-12 md:mb-16">
            <p
              class="text-sm font-medium tracking-widest uppercase text-[var(--theme-primary)] mb-3"
            >
              Projects
            </p>
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
              專案作品
            </h2>
            <p class="text-muted-foreground text-lg leading-relaxed">
              從構想到落地的完整紀錄，涵蓋 AI 應用、產品設計與全端開發
            </p>
          </div>
          <div class="fade-in">
            <ProjectsFall
              projects={sortedProjects}
              themes={themes}
              client:load
            />
          </div>
        </div>
      </div>
    </section>
  </div>

  <ProfileCardTigger client:load />
  <ProfileCardModal client:load />

  <style>
    .fade-in {
      opacity: 0;
      transform: translateY(24px);
      transition:
        opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
    );
    document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
  </script>
</BaseLayout>
