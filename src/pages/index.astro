---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { themes } from "@/lib/themes";
import Icon from "@/components/Icon.astro";
import { ProjectsFall } from "@/components/projects/ProjectsFall";
import { Button } from "@/components/ui/button";
import { ProfileCardTigger, ProfileCardModal } from "@/components/data/profile";
import AppCard from "@/components/apps/AppCard.astro";
import ArticleCard from "@/components/articles/ArticleCard.astro";
import { apps } from "@/data/apps";

const allProjects = await getCollection("projects");
const sortedProjects = allProjects.sort((a, b) => {
  if (a.data.pin && !b.data.pin) return -1;
  if (!a.data.pin && b.data.pin) return 1;
  return b.data.startDate.getTime() - a.data.startDate.getTime();
});

const allPosts = await getCollection("articles");
const sortedPosts = allPosts
  .sort((a, b) => {
    if (a.data.pin && !b.data.pin) return -1;
    if (!a.data.pin && b.data.pin) return 1;
    return b.data.date.getTime() - a.data.date.getTime();
  })
  .slice(0, 6);
---

<BaseLayout
  title="把繁瑣交給 AI，把時間還給靈感・亮點研創 LuMakes"
  description="把重複性工作外包給 AI，騰出空間做輕鬆思考與多樣創造。呂亮進的個人品牌，分享 AI 工作流、產品設計與全端開發。"
  ogImage="/assets/MetaTagCover.png"
  headerType="main"
>
  <div class="min-h-screen pt-20">
    <!-- Hero Section -->
    <section class="relative overflow-hidden">
      <div
        class="absolute inset-0 bg-gradient-to-b from-[var(--theme-primary-5)] via-transparent to-transparent"
      >
      </div>
      <div
        class="container mx-auto px-4 pt-24 pb-20 md:pt-40 md:pb-32 relative"
      >
        <div class="max-w-4xl mx-auto text-center">
          <p
            class="fade-in text-sm font-medium tracking-widest uppercase text-[var(--theme-primary)] mb-6"
          >
            亮點研創 LuMakes
          </p>
          <h1
            class="fade-in text-4xl sm:text-5xl md:text-7xl font-bold mb-8 bg-gradient-to-b from-gray-900 via-gray-800 to-gray-400 dark:from-white dark:via-gray-100 dark:to-gray-400 bg-clip-text text-transparent tracking-tight leading-[1.3] md:leading-[1.2]"
          >
            把繁瑣交給 AI<br class="hidden sm:block" />把時間還給靈感
          </h1>
          <p
            class="fade-in text-lg md:text-xl text-muted-foreground max-w-xl mx-auto leading-relaxed"
          >
            把重複性工作外包給 AI，騰出空間做輕鬆思考與多樣創造
          </p>
          <div class="fade-in flex items-center justify-center gap-4 mt-10">
            <a href="/articles/">
              <Button
                className="px-6 py-5 text-base rounded-full dark:bg-foreground text-white dark:text-background dark:opacity-75 dark:hover:opacity-100"
              >
                瀏覽文章
              </Button>
            </a>
            <a href="/about/">
              <Button
                variant="outline"
                className="px-6 py-5 text-base rounded-full"
              >
                認識我
              </Button>
            </a>
          </div>
        </div>
      </div>
      <div
        class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"
      >
      </div>
    </section>

    <!-- Personal Intro Section -->
    <section class="relative">
      <div class="container mx-auto px-4 py-16 md:py-20 relative">
        <div class="max-w-3xl mx-auto text-center">
          <p
            class="fade-in text-sm font-medium tracking-widest uppercase text-[var(--theme-primary)] mb-3"
          >
            About
          </p>
          <h2 class="fade-in text-2xl md:text-3xl font-bold mb-4 tracking-tight">
            我是呂亮進
          </h2>
          <p class="fade-in text-muted-foreground text-lg leading-relaxed">
            結合 AI 技術與設計思維的全端工程師。亮點研創 LuMakes 是我的個人品牌，記錄我怎麼把 AI 變成日常的共創夥伴，外包重複、留下創造。
          </p>
        </div>
      </div>
      <div
        class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"
      >
      </div>
    </section>

    <!-- Articles Section -->
    <section class="relative">
      <div
        class="absolute inset-0 bg-gradient-to-b from-transparent via-[var(--theme-primary-5)] to-transparent"
      >
      </div>
      <div class="container mx-auto px-4 py-20 md:py-32 relative">
        <div class="max-w-6xl mx-auto">
          <div class="fade-in max-w-2xl mb-12 md:mb-16">
            <p
              class="text-sm font-medium tracking-widest uppercase text-[var(--theme-primary)] mb-3"
            >
              Articles
            </p>
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
              文章
            </h2>
            <p class="text-muted-foreground text-lg leading-relaxed">
              每篇都圍繞一個主題，從選擇理由到搭配方式，完整分享我的使用經驗
            </p>
          </div>
          <div
            class="fade-in grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5"
          >
            {sortedPosts.map((post) => <ArticleCard post={post} />)}
          </div>
          <div class="fade-in mt-10 text-center">
            <a href="/articles/">
              <Button
                variant="outline"
                className="px-6 py-5 text-base rounded-full hover:[&>svg]:ms-1"
              >
                查看所有文章
                <Icon name="arrow-right" class="transition-all duration-300" />
              </Button>
            </a>
          </div>
        </div>
      </div>
      <div
        class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"
      >
      </div>
    </section>

    <!-- APP Section -->
    <section class="relative">
      <div class="container mx-auto px-4 py-20 md:py-32">
        <div class="max-w-6xl mx-auto">
          <div class="fade-in max-w-2xl mb-12 md:mb-16">
            <p
              class="text-sm font-medium tracking-widest uppercase text-[var(--theme-primary)] mb-3"
            >
              Apps
            </p>
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
              自建應用
            </h2>
            <p class="text-muted-foreground text-lg leading-relaxed">
              為了解決自己的需求而打造的小工具
            </p>
          </div>
          <div class="fade-in grid grid-cols-1 gap-5">
            {apps.slice(0, 3).map((app) => <AppCard app={app} />)}
          </div>
          <div class="fade-in mt-10 text-center">
            <a href="/apps/">
              <Button
                variant="outline"
                className="px-6 py-5 text-base rounded-full hover:[&>svg]:ms-1"
              >
                查看所有應用
                <Icon name="arrow-right" class="transition-all duration-300" />
              </Button>
            </a>
          </div>
        </div>
      </div>
      <div
        class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"
      >
      </div>
    </section>

    <!-- Projects Section -->
    <section class="relative">
      <div class="container mx-auto px-4 py-20 md:py-32">
        <div class="max-w-6xl mx-auto">
          <div class="fade-in max-w-2xl mb-12 md:mb-16">
            <p
              class="text-sm font-medium tracking-widest uppercase text-[var(--theme-primary)] mb-3"
            >
              Projects
            </p>
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
              專案作品
            </h2>
            <p class="text-muted-foreground text-lg leading-relaxed">
              從構想到落地的完整紀錄，涵蓋 AI 應用、產品設計與全端開發
            </p>
          </div>
          <div class="fade-in">
            <ProjectsFall
              projects={sortedProjects}
              themes={themes}
              compact
              client:load
            />
          </div>
        </div>
      </div>
    </section>
  </div>

  <ProfileCardTigger client:load />
  <ProfileCardModal client:load />

  <style>
    .fade-in {
      opacity: 0;
      transform: translateY(24px);
      transition:
        opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script>
    function initFadeIn() {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0, rootMargin: "0px 0px -40px 0px" },
      );

      document.querySelectorAll(".fade-in").forEach((el) => {
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight && rect.bottom > 0) {
          el.classList.add("visible");
        } else {
          observer.observe(el);
        }
      });
    }

    initFadeIn();

    window.addEventListener("pageshow", (e) => {
      if (e.persisted) {
        document.querySelectorAll(".fade-in:not(.visible)").forEach((el) => {
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight && rect.bottom > 0) {
            el.classList.add("visible");
          }
        });
        initFadeIn();
      }
    });
  </script>
</BaseLayout>
