---
import { getCollection } from "astro:content";
import ArticleSlugPage from "@/components/pages/ArticleSlugPage.astro";
import { filterByLocale } from "@/i18n";

export async function getStaticPaths() {
  const allPosts = await getCollection("articles");
  const posts = filterByLocale(allPosts, "en");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
---

<ArticleSlugPage post={post} Content={Content} headings={headings} locale="en" />
