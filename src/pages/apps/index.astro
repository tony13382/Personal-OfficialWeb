---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { apps } from "@/data/apps";
import { Card } from "@/components/ui/card";
import Icon from "@/components/Icon.astro";
---

<BaseLayout
  title="APP - 自建應用"
  description="為了解決自己的需求而打造的小工具"
  ogImage="/assets/MetaTagCover.png"
  headerType="main"
>
  <div class="min-h-screen pt-20">
    <section class="relative overflow-hidden">
      <div
        class="absolute inset-0 bg-gradient-to-b from-[var(--theme-primary-5)] via-transparent to-transparent"
      >
      </div>
      <div
        class="container mx-auto px-4 pt-24 pb-20 md:pt-40 md:pb-32 relative"
      >
        <div class="max-w-4xl mx-auto text-center">
          <p
            class="fade-in text-sm font-medium tracking-widest uppercase text-[var(--theme-primary)] mb-6"
          >
            Apps
          </p>
          <h1
            class="fade-in text-4xl sm:text-5xl md:text-7xl font-bold mb-8 bg-gradient-to-b from-gray-900 via-gray-800 to-gray-400 bg-clip-text text-transparent tracking-tight leading-[1.3] md:leading-[1.2]"
          >
            自建應用
          </h1>
          <p
            class="fade-in text-lg md:text-xl text-muted-foreground max-w-xl mx-auto leading-relaxed"
          >
            為了解決自己的需求而打造的小工具
          </p>
        </div>
      </div>
      <div
        class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"
      >
      </div>
    </section>

    <section class="relative">
      <div
        class="absolute inset-0 bg-gradient-to-b from-transparent via-[var(--theme-primary-5)] to-transparent"
      >
      </div>
      <div class="container mx-auto px-4 py-20 md:py-32 relative">
        <div class="max-w-6xl mx-auto">
          <div class="fade-in grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-5">
            {
              apps.map((app) => (
                <a href={`/apps/${app.slug}/`} class="group block no-underline">
                  <Card className="shadow-none border hover:shadow-xl transition-all duration-300 hover:-translate-y-1 overflow-hidden h-full bg-background/80 backdrop-blur-sm">
                    {/* Mobile / Tablet: stacked */}
                    <div class="lg:hidden">
                      <div class="overflow-hidden bg-gradient-to-br from-[var(--theme-primary-10)] to-[var(--theme-primary-5)]">
                        {app.cover ? (
                          <img
                            src={app.cover?.src}
                            alt={app.name}
                            class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-500"
                            loading="lazy"
                            decoding="async"
                          />
                        ) : (
                          <div class="w-full aspect-video flex items-center justify-center">
                            <Icon
                              name="app-window"
                              class="size-12 text-[var(--theme-primary-30)]"
                            />
                          </div>
                        )}
                      </div>
                      <div class="flex flex-col gap-1.5 px-6 py-4">
                        {app.icon && (
                          <img
                            src={app.icon?.src}
                            alt={`${app.name} icon`}
                            class="size-12 rounded-xl mt-2 mb-1 shadow-md"
                            loading="lazy"
                            decoding="async"
                          />
                        )}
                        <h3 class="font-bold leading-snug group-hover:text-[var(--theme-primary)] transition-colors">
                          {app.name}
                        </h3>
                        <p class="text-xs text-muted-foreground leading-relaxed">
                          {app.description}
                        </p>
                      </div>
                    </div>

                    {/* Desktop: row with gradient */}
                    <div class="hidden lg:flex flex-row items-stretch">
                      <div class="relative flex-[2] overflow-hidden">
                        {app.cover ? (
                          <img
                            src={app.cover?.src}
                            alt={app.name}
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                            loading="lazy"
                            decoding="async"
                          />
                        ) : (
                          <div class="w-full h-full flex items-center justify-center bg-muted">
                            <Icon
                              name="app-window"
                              class="size-12 text-[var(--theme-primary-30)]"
                            />
                          </div>
                        )}
                        <div class="absolute inset-0" style="background: linear-gradient(to right, transparent 80%, white 100%)" />
                      </div>
                      <div class="flex-[1] flex flex-col justify-center gap-2 px-6">
                        {app.icon && (
                          <img
                            src={app.icon?.src}
                            alt={`${app.name} icon`}
                            class="size-14 rounded-2xl"
                            loading="lazy"
                            decoding="async"
                          />
                        )}
                        <h3 class="text-xl font-bold leading-snug group-hover:text-[var(--theme-primary)] transition-colors">
                          {app.name}
                        </h3>
                        <p class="text-sm text-muted-foreground leading-relaxed">
                          {app.description}
                        </p>
                      </div>
                    </div>
                  </Card>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </section>
  </div>

  <style>
    .fade-in {
      opacity: 0;
      transform: translateY(24px);
      transition:
        opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
    );
    document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
  </script>
</BaseLayout>
